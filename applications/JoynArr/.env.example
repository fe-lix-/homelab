# ── Ports ─────────────────────────────────────────────────────────────────────
INDEXER_PORT=5008           # Newznab API — add as indexer in Sonarr/Prowlarr
DOWNLOADER_PORT=5007        # SABnzbd API — add as download client in Sonarr

# ── Storage ───────────────────────────────────────────────────────────────────
# Path where completed MKV files appear (as seen from outside the container)
DOWNLOAD_FOLDER_PATH_MAPPING=/downloads/completed

# ── Joyn API ──────────────────────────────────────────────────────────────────
JOYN_API_BASE_URL=https://api.joyn.de
JOYN_API_KEY=4f0fd9f18abbe3cf0e87fdb556bc39c8

# ── TVDB proxy ────────────────────────────────────────────────────────────────
# Required for Sonarr tvdbid lookups. Must expose GET /shows/{tvdbid}
TVDB_API_BASE_URL=https://your-tvdb-proxy/api/v1

# ── German IP proxy (required for Joyn auth) ──────────────────────────────────
# Supports socks5:// and http:// proxies.
# Only used for auth.joyn.de + entitlement.p7s1.io — CDN downloads go direct.
# Example: socks5://username:password@proxy-host:port
BRIGHTDATA_PROXY_URL=

# ── Widevine / RemoteCDM ──────────────────────────────────────────────────────
# pywidevine-compatible RemoteCDM server for automatic content key extraction.
# cdrm-project.com provides a free public L3 device — self-host from:
#   https://github.com/tpd94/cdrm-project
REMOTE_CDM_HOST=https://cdrm-project.com/remotecdm/widevine
REMOTE_CDM_SECRET=CDRM
REMOTE_CDM_DEVICE=public

# Optional: skip RemoteCDM and provide keys directly (comma-separated KID:KEY hex pairs)
# JOYN_DECRYPTION_KEYS=1ad21e5a1b5030878937b19e430c9132:fc6c40ffcea35a574f7f48a8fcce0e64

# ── Docker / system ───────────────────────────────────────────────────────────
TZ=Europe/Berlin
PUID=1000
PGID=1000
