#!/usr/bin/env bash
set -euo pipefail

REPO="${1:-local}"
ACTION="${2:-}"

case "$REPO" in
  local) source {{ backup_config_dir }}/restic-env-local ;;
  b2)    source {{ backup_config_dir }}/restic-env-b2 ;;
  *)
    echo "Usage: $0 [local|b2] [snapshots|list SNAPSHOT|restore SNAPSHOT TARGET|restore-db SNAPSHOT|restore-service PATH [SNAPSHOT [TARGET]]]"
    exit 1
    ;;
esac

case "$ACTION" in
  snapshots)
    restic snapshots
    ;;
  list)
    SNAPSHOT="${3:?Snapshot ID required}"
    restic ls "$SNAPSHOT"
    ;;
  restore)
    SNAPSHOT="${3:?Snapshot ID required}"
    TARGET="${4:?Target path required}"
    restic restore "$SNAPSHOT" --target "$TARGET"
    echo "Restored snapshot $SNAPSHOT to $TARGET"
    ;;
  restore-db)
    SNAPSHOT="${3:?Snapshot ID required}"
    TMPDIR=$(mktemp -d)
    restic restore "$SNAPSHOT" --target "$TMPDIR" --include "{{ backup_immich_dump_path }}"
    echo "Restoring Immich database from dump..."
    docker exec -i immich-db psql -U immich -d immich < "$TMPDIR{{ backup_immich_dump_path }}"
    rm -rf "$TMPDIR"
    echo "Database restored successfully."
    ;;
  restore-service)
    PATH_FILTER="${3:?Service path required (e.g. /opt/minecraft/data)}"
    SNAPSHOT="${4:-latest}"
    TARGET="${5:-/}"
    SERVICE_DIR=$(echo "$PATH_FILTER" | grep -oP '^/opt/[^/]+')
    if [ -n "$SERVICE_DIR" ] && [ -f "$SERVICE_DIR/docker-compose.yml" ]; then
      echo "Stopping $SERVICE_DIR..."
      (cd "$SERVICE_DIR" && docker compose down)
    fi
    echo "Restoring $PATH_FILTER from snapshot $SNAPSHOT to $TARGET..."
    restic restore "$SNAPSHOT" --target "$TARGET" --include "$PATH_FILTER"
    echo "Done. Start the service manually: cd $SERVICE_DIR && docker compose up -d"
    ;;
  *)
    echo "Usage: $0 [local|b2] [snapshots|list SNAPSHOT|restore SNAPSHOT TARGET|restore-db SNAPSHOT|restore-service PATH [SNAPSHOT [TARGET]]]"
    exit 1
    ;;
esac
