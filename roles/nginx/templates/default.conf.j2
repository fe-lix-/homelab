server {
    listen {{ nginx_port }} ssl;
    server_name uptime.{{ base_domain }};
    {{ ssl_params() }}
    {{ local_guard() }}
    {{ authelia_location() }}

    # Public paths — granular with slug/filename validation
    location ~ ^/status/[0-9a-zA-Z_-]+$ {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    location ~ ^/api/status-page/heartbeat/[0-9a-zA-Z_-]+$ {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~ ^/api/push/[0-9a-zA-Z_-]+$ {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~ ^/api/badge/[0-9a-zA-Z_-]+/[a-z]+$ {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /assets/ {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
    }

    location ~ ^/upload/[0-9a-zA-Z_-]+\.[a-z]+$ {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
    }

    location = /icon.svg {
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
    }

    # Everything else (dashboard) — admins only via Authelia
    location / {
        {{ authelia_auth() }}
        proxy_pass http://127.0.0.1:{{ uptime_kuma_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

