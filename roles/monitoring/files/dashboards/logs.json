{
  "title": "Logs",
  "uid": "homelab-logs",
  "description": "Docker container and systemd journal logs from Alloy/Loki",
  "tags": ["logs"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "type": 1, "label": "container", "stream": "", "refId": "LokiVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+"
      },
      {
        "name": "unit",
        "label": "Systemd unit",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": { "type": 1, "label": "unit", "stream": "", "refId": "LokiVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+"
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "query": "",
        "current": { "selected": false, "text": "", "value": "" },
        "options": [{ "selected": true, "text": "", "value": "" }]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log volume by container",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 18, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (container) (count_over_time({container=~\"$container\"} [$__auto]))",
          "legendFormat": "{{container}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 2,
      "title": "Errors & warnings",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({container=~\"$container\"} |~ \"(?i)(error|err|fatal|panic)\" [$__range]))",
          "legendFormat": "Errors",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 3,
      "title": "Journal errors & warnings",
      "type": "stat",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum(count_over_time({unit=~\"$unit\"} |~ \"(?i)(error|failed|fatal)\" [$__range]))",
          "legendFormat": "Journal errors",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 4,
      "title": "Docker container logs",
      "type": "row",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "Container logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "signature",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{container=~\"$container\"} |= \"$search\"",
          "queryType": "range",
          "maxLines": 1000
        }
      ]
    },
    {
      "id": 6,
      "title": "Systemd journal",
      "type": "row",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Journal logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "signature",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{unit=~\"$unit\"} |= \"$search\"",
          "queryType": "range",
          "maxLines": 500
        }
      ]
    }
  ]
}
