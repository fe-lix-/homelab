{
  "title": "Komga Reading Activity",
  "uid": "komga-reading",
  "tags": ["komga", "reading"],
  "timezone": "browser",
  "refresh": "5m",
  "schemaVersion": 39,
  "time": { "from": "now-90d", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Books completed (lifetime)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "komga-sqlite" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "rawQueryText": "SELECT COUNT(*) AS books FROM READ_PROGRESS WHERE COMPLETED = 1;"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pages read (current snapshot)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "komga-sqlite" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "rawQueryText": "SELECT SUM(CASE WHEN rp.COMPLETED THEN m.PAGE_COUNT ELSE rp.PAGE END) AS pages FROM READ_PROGRESS rp JOIN MEDIA m ON rp.BOOK_ID = m.BOOK_ID;"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Books in progress",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "komga-sqlite" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "rawQueryText": "SELECT COUNT(*) AS books FROM READ_PROGRESS WHERE COMPLETED = 0;"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pages viewed today",
      "description": "Pages viewed in the last 24h from nginx access logs (GET /api/v1/books/<id>/pages/<n>, excluding nginx buffering-warning duplicates). Independent of bulk mark-as-read (which hits PATCH /read-progress, not GET /pages).",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"nginx\"} |= \"GET /api/v1/books/\" |= \"/pages/\" != \"[warn]\" [24h]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pages viewed per day",
      "description": "Daily page views from nginx access logs. One row per real GET /api/v1/books/<id>/pages/<n> request (nginx buffering-warning duplicates filtered out). Independent of bulk mark-as-read.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"nginx\"} |= \"GET /api/v1/books/\" |= \"/pages/\" != \"[warn]\" [1d]))",
          "queryType": "range",
          "step": "1d",
          "legendFormat": "pages"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pages viewed per hour, last 24h",
      "description": "Hourly buckets of page views (nginx access logs, warns filtered). Useful for spotting active reading sessions vs. background activity.",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({container=\"nginx\"} |= \"GET /api/v1/books/\" |= \"/pages/\" != \"[warn]\" [1h]))",
          "queryType": "range",
          "step": "1h",
          "legendFormat": "pages"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Reading totals per user",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "komga-sqlite" },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "rawQueryText": "SELECT u.EMAIL AS user, SUM(rp.COMPLETED) AS books_finished, COUNT(*) - SUM(rp.COMPLETED) AS in_progress, SUM(CASE WHEN rp.COMPLETED THEN m.PAGE_COUNT ELSE rp.PAGE END) AS pages FROM READ_PROGRESS rp JOIN USER u ON rp.USER_ID = u.ID JOIN MEDIA m ON rp.BOOK_ID = m.BOOK_ID GROUP BY u.EMAIL ORDER BY pages DESC;"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recently finished books",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "komga-sqlite" },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "queryType": "table",
          "rawQueryText": "SELECT rp.READ_DATE AS finished, u.EMAIL AS user, sm.TITLE AS series, bm.TITLE AS book, m.PAGE_COUNT AS pages FROM READ_PROGRESS rp JOIN USER u ON rp.USER_ID = u.ID JOIN BOOK b ON rp.BOOK_ID = b.ID JOIN BOOK_METADATA bm ON b.ID = bm.BOOK_ID JOIN SERIES_METADATA sm ON b.SERIES_ID = sm.SERIES_ID JOIN MEDIA m ON b.ID = m.BOOK_ID WHERE rp.COMPLETED = 1 ORDER BY rp.READ_DATE DESC LIMIT 50;"
        }
      ]
    }
  ]
}
