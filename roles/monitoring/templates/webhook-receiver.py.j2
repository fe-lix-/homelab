#!/usr/bin/env python3
"""Webhook receiver that forwards events to Loki."""
import json
import time
import urllib.request
from http.server import HTTPServer, BaseHTTPRequestHandler

LOKI_URL = "http://loki:3100/loki/api/v1/push"


def push_to_loki(labels, message):
    entry = {
        "streams": [
            {
                "stream": labels,
                "values": [[str(int(time.time() * 1e9)), message]],
            }
        ]
    }
    req = urllib.request.Request(
        LOKI_URL,
        data=json.dumps(entry).encode(),
        headers={"Content-Type": "application/json"},
    )
    urllib.request.urlopen(req, timeout=5)


class WebhookHandler(BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length) if length else b""

        try:
            data = json.loads(body) if body else {}
        except json.JSONDecodeError:
            self.send_response(400)
            self.end_headers()
            return

        if self.path == "/webhook/jellyfin":
            self.handle_jellyfin(data)
        else:
            self.send_response(404)
            self.end_headers()
            return

        self.send_response(204)
        self.end_headers()

    def handle_jellyfin(self, data):
        event_type = data.get("NotificationType", "Unknown")
        name = data.get("Name", "")
        series = data.get("SeriesName", "")
        year = data.get("Year", "")
        item_type = data.get("ItemType", "")

        if series:
            title = f"{series} - {name}"
        elif name and year:
            title = f"{name} ({year})"
        elif name:
            title = name
        else:
            title = "Unknown"

        labels = {
            "job": "webhooks",
            "source": "jellyfin",
            "event": event_type,
        }
        if item_type:
            labels["item_type"] = item_type

        message = json.dumps({
            "event": event_type,
            "title": title,
            "item_type": item_type,
            "raw": data,
        })

        push_to_loki(labels, message)
        print(f"[jellyfin] {event_type}: {title}")

    def log_message(self, format, *args):
        pass  # Suppress default access logs


if __name__ == "__main__":
    server = HTTPServer(("0.0.0.0", 9095), WebhookHandler)
    print("Webhook receiver listening on :9095")
    server.serve_forever()
