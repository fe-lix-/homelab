#!/usr/bin/env python3
"""Provision Komga users from Authelia user list."""
import json
import sys
import urllib.request
import urllib.error
import base64

KOMGA_URL = "http://127.0.0.1:{{ komga_port }}"
ADMIN_EMAIL = "{{ komga_admin_email }}"
ADMIN_PASSWORD = "{{ komga_admin_password }}"

USERS = [
{% for user in authelia_users %}
    {"email": "{{ user.email }}", "password": "authelia-oidc-user"},
{% endfor %}
]


def api_request(path, method="GET", data=None):
    url = f"{KOMGA_URL}{path}"
    creds = base64.b64encode(f"{ADMIN_EMAIL}:{ADMIN_PASSWORD}".encode()).decode()
    headers = {"Authorization": f"Basic {creds}", "Content-Type": "application/json"}
    body = json.dumps(data).encode() if data else None
    req = urllib.request.Request(url, data=body, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return resp.status, json.loads(resp.read()) if resp.read else {}
    except urllib.error.HTTPError as e:
        return e.code, e.read().decode()


def main():
    changed = False

    # Get existing users
    status, existing = api_request("/api/v2/users")
    if status != 200:
        print(f"ERROR: Failed to list users: {status}", file=sys.stderr)
        sys.exit(1)

    existing_emails = {u["email"].lower() for u in existing}

    for user in USERS:
        email = user["email"]
        if email.lower() == ADMIN_EMAIL.lower():
            continue
        if email.lower() in existing_emails:
            print(f"OK: {email} already exists")
            continue

        status, result = api_request("/api/v2/users", method="POST", data={
            "email": email,
            "password": user["password"],
        })
        if status in (200, 201):
            print(f"CHANGED: Created user {email}")
            changed = True
        else:
            print(f"ERROR: Failed to create {email}: {status} {result}", file=sys.stderr)
            sys.exit(1)

    if not changed:
        print("All users already exist.")


if __name__ == "__main__":
    main()
