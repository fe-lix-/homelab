PORT = {{ manga_scheduler_ui_port }}
{% raw %}
COMIC_EXTENSIONS = {".cbz", ".cbr", ".pdf"}
IMAGE_EXTENSIONS = {".jpg", ".jpeg", ".png", ".webp", ".gif", ".bmp", ".tiff"}


def natural_sort_key(path: Path) -> list:
    """Sort key that treats numeric parts as integers for natural ordering."""
    return [
        int(part) if part.isdigit() else part.lower()
        for part in re.split(r"(\d+)", path.name)
    ]


def count_pages(filepath: Path) -> int:
    """Count image pages inside a comic archive."""
    suffix = filepath.suffix.lower()
    if suffix == ".cbz":
        try:
            with zipfile.ZipFile(filepath) as zf:
                return sum(
                    1 for name in zf.namelist()
                    if Path(name).suffix.lower() in IMAGE_EXTENSIONS
                )
        except zipfile.BadZipFile:
            pass
    elif suffix == ".cbr":
        try:
            result = subprocess.run(
                ["7z", "l", "-slt", str(filepath)],
                capture_output=True, text=True, timeout=30,
            )
            return sum(
                1 for line in result.stdout.splitlines()
                if line.startswith("Path = ")
                and Path(line.split(" = ", 1)[1]).suffix.lower() in IMAGE_EXTENSIONS
            )
        except (subprocess.TimeoutExpired, OSError):
            pass
    return 30


VOLUME_SUFFIX_RE = re.compile(
    r"\s*-\s*(Tomo|Vol\.?|Volume|Book)\s+\d+.*$", re.IGNORECASE
)
JOURNAL_LINE_RE = re.compile(r"^(\S+)\s+\S+\s+\S+\s+(.+)$")
RUN_START_RE = re.compile(r"^Series: '(.+)' \(\d+ files? remaining\)$")
MOVE_FILE_RE = re.compile(r"^Moving: .+ -> .+/(.+)$")


# --- Data functions ---

def series_name_from_file(stem: str) -> str:
    return VOLUME_SUFFIX_RE.sub("", stem).strip()


def discover_series() -> dict:
    """Return {series_name: [path, ...]} for files in UPLOAD_DIR."""
    series: dict = {}
    if not UPLOAD_DIR.is_dir():
        return series
    for entry in sorted(UPLOAD_DIR.iterdir()):
        if entry.is_dir():
            files = sorted(
                (f for f in entry.iterdir()
                if f.is_file() and f.suffix.lower() in COMIC_EXTENSIONS),
                key=natural_sort_key,
            )
            if files:
                series[entry.name] = files
        elif entry.is_file() and entry.suffix.lower() in COMIC_EXTENSIONS:
            name = series_name_from_file(entry.stem)
            series.setdefault(name, []).append(entry)
    for name in series:
        series[name] = sorted(series[name], key=natural_sort_key)
    return series


def load_state() -> dict:
    if STATE_FILE.exists():
        with STATE_FILE.open() as f:
            return json.load(f)
    return {"series_order": [], "current_index": 0}


def load_schedule() -> list[str]:
    """Load the active series list. Empty list means all series are active."""
    if SCHEDULE_FILE.exists():
        try:
            data = json.loads(SCHEDULE_FILE.read_text())
            return data.get("active_series", [])
        except (json.JSONDecodeError, OSError):
            pass
    return []


def save_schedule(active_series: list[str]):
    SCHEDULE_FILE.write_text(json.dumps({"active_series": active_series}, indent=2))


def get_delivery_log(lines: int = 500) -> list[dict]:
    """Return parsed delivery runs from the systemd journal, newest first."""
    try:
        result = subprocess.run(
            ["journalctl", "-u", "manga-scheduler.service",
             "--no-pager", "-n", str(lines), "-o", "short-iso"],
            capture_output=True, text=True, timeout=5
        )
        raw = result.stdout.strip()
    except Exception:
        return []

    runs = []
    current: dict | None = None

    for line in raw.splitlines():
        m = JOURNAL_LINE_RE.match(line)
        if not m:
            continue
        timestamp_str, message = m.group(1), m.group(2)

        series_m = RUN_START_RE.match(message)
        if series_m:
            if current:
                runs.append(current)
            try:
                dt = datetime.datetime.fromisoformat(timestamp_str)
                formatted = dt.strftime("%Y-%m-%d %H:%M")
            except Exception:
                formatted = timestamp_str
            current = {"time": formatted, "series": series_m.group(1), "volumes": []}
            continue

        if current is None:
            continue

        move_m = MOVE_FILE_RE.match(message)
        if move_m:
            current["volumes"].append(move_m.group(1))

    if current:
        runs.append(current)

    runs.reverse()
    return runs


def get_timer_info() -> dict:
    try:
        result = subprocess.run(
            ["systemctl", "show", "manga-scheduler.timer",
             "--property=NextElapseUSecRealtime,LastTriggerUSec,ActiveState"],
            capture_output=True, text=True, timeout=5
        )
        props = {}
        for line in result.stdout.strip().splitlines():
            k, _, v = line.partition("=")
            props[k] = v
        return props
    except Exception:
        return {}


def read_download_status() -> dict:
    if DOWNLOAD_STATUS_FILE.exists():
        try:
            return json.loads(DOWNLOAD_STATUS_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return {"state": "idle"}


def read_download_history() -> list[dict]:
    if DOWNLOAD_HISTORY_FILE.exists():
        try:
            return json.loads(DOWNLOAD_HISTORY_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return []


def is_download_running() -> bool:
    if not DOWNLOAD_PID_FILE.exists():
        return False
    try:
        pid = int(DOWNLOAD_PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError):
        return False


def get_next_series(series_map: dict, state: dict, active_series: list[str]) -> str | None:
    """Get the next series that would be delivered."""
    series_order = state.get("series_order", [])
    current_index = state.get("current_index", 0)
    if not series_order:
        return None
    order = [s for s in series_order if s in series_map]
    if active_series:
        filtered = [s for s in order if s in active_series]
        if filtered:
            order = filtered
    for offset in range(len(order)):
        idx = (current_index + offset) % len(order)
        name = order[idx % len(order)] if order else None
        if name and name in series_map:
            return name
    return None


def simulate_deliveries(series_map: dict, state: dict, active_series: list[str], count: int = 10) -> list[dict]:
    """Simulate the next N deliveries based on current state."""
    series_order = state.get("series_order", [])
    current_index = state.get("current_index", 0)
    if not series_order:
        return []

    order = [s for s in series_order if s in series_map]
    if active_series:
        filtered = [s for s in order if s in active_series]
        if filtered:
            order = filtered
    if not order:
        return []

    # Clone file data for simulation
    remaining = {}
    for s, files in series_map.items():
        remaining[s] = {
            "count": len(files),
            "total_pages": sum(count_pages(f) for f in files),
        }

    index = current_index % len(order) if order else 0
    preview = []

    for _ in range(count):
        picked = None
        for offset in range(len(order)):
            idx = (index + offset) % len(order)
            name = order[idx]
            if remaining.get(name, {}).get("count", 0) > 0:
                picked = name
                index = (idx + 1) % len(order)
                break
        if not picked:
            break

        r = remaining[picked]
        # Estimate batch: all files if total pages <= target, else accumulate until >= target
        if r["total_pages"] <= TARGET_PAGES:
            est_files = r["count"]
            est_pages = r["total_pages"]
        else:
            avg_pages = r["total_pages"] / r["count"] if r["count"] else 1
            est_files = max(1, min(r["count"], round(TARGET_PAGES / avg_pages)))
            est_pages = round(est_files * avg_pages)

        preview.append({
            "series": picked,
            "files": est_files,
            "pages": est_pages,
            "remaining_after": r["count"] - est_files,
        })

        r["count"] -= est_files
        r["total_pages"] -= est_pages

    return preview


