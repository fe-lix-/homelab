# --- Navigation ---

def _nav(active: str) -> str:
    tabs = [("Delivery", "/"), ("Download", "/download-page"), ("Schedule", "/schedule")]
    html = "<nav class='nav'>"
    for label, href in tabs:
        cls = " class='active'" if label == active else ""
        html += f"<a href='{href}'{cls}>{label}</a>"
    html += "</nav>"
    return html


def _page(title: str, active_tab: str, body: str, msg: str = "", error: bool = False, scripts: str = "") -> str:
    msg_html = ""
    if msg:
        cls = "error" if error else "success"
        msg_html = f"<div class='{cls}'>{escape(msg)}</div>"
    return (
        "<!DOCTYPE html>\n<html lang='en'>\n<head>\n"
        "  <meta charset='UTF-8'>\n"
        "  <meta name='viewport' content='width=device-width, initial-scale=1'>\n"
        f"  <title>{escape(title)} - Manga Scheduler</title>\n"
        f"  <style>{CSS}</style>\n"
        "</head>\n<body>\n"
        "  <h1>Manga Scheduler</h1>\n"
        + _nav(active_tab) + msg_html + body + scripts +
        "\n</body>\n</html>"
    )


# --- Delivery page ---

def render_delivery(msg: str = "", error: bool = False) -> str:
    series_map = discover_series()
    state = load_state()
    timer = get_timer_info()
    active_series = load_schedule()
    delivery_runs = get_delivery_log()

    next_series = get_next_series(series_map, state, active_series)
    next_run = timer.get("NextElapseUSecRealtime", "n/a")
    last_run = timer.get("LastTriggerUSec", "n/a")

    info = (
        "<div class='info'>"
        f"<span>Next auto-run: <strong>{escape(next_run)}</strong></span>"
        f"<span>Last run: <strong>{escape(last_run)}</strong></span>"
        f"<span>Next in queue: <strong>{escape(next_series or 'none')}</strong></span>"
        "</div>"
    )

    # Series table
    rows = []
    for name, files in sorted(series_map.items()):
        total_mb = sum(f.stat().st_size for f in files) / (1024 * 1024)
        is_next = "\u2713" if name == next_series else ""
        safe_name = escape(name)
        row_class = ' class="next"' if name == next_series else ""
        rows.append(
            f"<tr{row_class}>"
            f"<td>{safe_name}</td>"
            f"<td>{len(files)}</td>"
            f"<td>{'%.1f' % total_mb} MB</td>"
            f"<td>{is_next}</td>"
            "<td>"
            f"<form method='post' action='/deliver' onsubmit=\"return confirm('Deliver now: {safe_name}?')\">"
            f"<input type='hidden' name='series' value='{safe_name}'>"
            "<button type='submit'>Deliver Now</button>"
            "</form>"
            "</td>"
            "</tr>"
        )
    rows_html = "\n".join(rows) if rows else "<tr><td colspan='5' class='empty'>No series in upload queue.</td></tr>"

    table = (
        "<table><thead><tr>"
        "<th>Series</th><th>Files</th><th>Size</th><th>Next</th><th>Action</th>"
        "</tr></thead><tbody>\n" + rows_html + "\n</tbody></table>"
    )

    # Delivery log
    if delivery_runs:
        log_rows = []
        for run in delivery_runs:
            vols = ", ".join(escape(v) for v in run["volumes"]) or "\u2014"
            log_rows.append(
                f"<tr><td>{escape(run['time'])}</td>"
                f"<td>{escape(run['series'])}</td>"
                f"<td class='volumes'>{vols}</td></tr>"
            )
        log_html = (
            "<div style='margin-top:1.5rem'><h2>Delivery Log</h2>"
            "<div class='log-scroll'><table>"
            "<thead><tr><th>Time</th><th>Series</th><th>Volumes</th></tr></thead>"
            "<tbody>" + "\n".join(log_rows) + "</tbody></table></div></div>"
        )
    else:
        log_html = "<div style='margin-top:1.5rem'><h2>Delivery Log</h2><p class='empty'>No deliveries recorded yet.</p></div>"

    return _page("Delivery", "Delivery", info + table + log_html, msg, error)


# --- Download page ---

def render_download(msg: str = "", error: bool = False) -> str:
    running = is_download_running()

    # Form
    if running:
        form = (
            "<div class='section'><h2>New Download</h2>"
            "<form class='dl-form'>"
            "<div><label>URL</label><br>"
            "<input type='text' name='url' disabled placeholder='Download in progress...'></div>"
            "<div><label>Series name</label><br>"
            "<input type='text' name='series' disabled></div>"
            "<button type='submit' disabled>Downloading...</button>"
            "</form>"
            "<div id='dl-progress' class='dl-progress'></div>"
            "</div>"
        )
    else:
        form = (
            "<div class='section'><h2>New Download</h2>"
            "<form class='dl-form' method='post' action='/download'>"
            "<div><label>URL</label><br>"
            "<input type='text' name='url' placeholder='https://tomosmanga.com/... or https://sushiscan.net/...' required></div>"
            "<div><label>Series name (optional)</label><br>"
            "<input type='text' name='series' placeholder='Auto-detect'></div>"
            "<button type='submit'>Start Download</button>"
            "</form>"
            "<div id='dl-progress' class='dl-progress'></div>"
            "</div>"
        )

    # Download history cards
    history = read_download_history()
    if history:
        cards = []
        for entry in reversed(history):
            started = entry.get("started", "")
            try:
                dt = datetime.datetime.fromisoformat(started)
                started = dt.strftime("%Y-%m-%d %H:%M")
            except Exception:
                pass
            state = entry.get("state", "unknown")
            is_ok = state == "completed"
            badge = f"<span class='badge-ok'>Completed</span>" if is_ok else f"<span class='badge-fail'>Failed</span>"
            count = f"{entry.get('completed', 0)}/{entry.get('total', 0)} volumes"

            retry_html = ""
            if not is_ok and entry.get("url") and not running:
                safe_url = escape(entry.get("url", ""))
                safe_series = escape(entry.get("series", ""))
                retry_html = (
                    f"<form method='post' action='/download' style='display:inline'>"
                    f"<input type='hidden' name='url' value='{safe_url}'>"
                    f"<input type='hidden' name='series' value='{safe_series}'>"
                    f"<button type='submit' class='retry-btn'>Retry</button>"
                    f"</form>"
                )

            errors = entry.get("errors", [])
            errors_html = ""
            if errors:
                err_items = "".join(f"<li>{escape(e)}</li>" for e in errors)
                errors_html = (
                    f"<div class='dl-card-errors'>"
                    f"<details><summary>{len(errors)} error(s)</summary>"
                    f"<ul>{err_items}</ul></details></div>"
                )

            cards.append(
                f"<div class='dl-card'>"
                f"<div class='dl-card-header'>"
                f"<span class='dl-card-series'>{escape(entry.get('series', ''))}</span>"
                f"<span class='dl-card-date'>{escape(started)}</span>"
                f"</div>"
                f"<div class='dl-card-meta'>{badge} <span>{escape(count)}</span> {retry_html}</div>"
                f"{errors_html}"
                f"</div>"
            )
        history_html = "<div style='margin-top:1.5rem'><h2>Download History</h2>" + "\n".join(cards) + "</div>"
    else:
        history_html = "<div style='margin-top:1.5rem'><h2>Download History</h2><p class='empty'>No downloads yet.</p></div>"

    # JS polling for progress
    scripts = """<script>
(function() {
  var prog = document.getElementById('dl-progress');
  var polling = null;
  function update() {
    fetch('/api/download-status').then(function(r) { return r.json(); }).then(function(d) {
      if (d.state === 'idle') { prog.innerHTML = ''; return; }
      var h = '<div class="status-line">Series: <strong>' + esc(d.series || '') + '</strong> &mdash; ';
      if (d.state === 'running') {
        h += '<span style="color:#fbbf24">' + esc(d.current || '') + '</span>';
        h += ' (' + (d.completed || 0) + '/' + (d.total || 0) + ' volumes)';
      } else if (d.state === 'completed') {
        h += '<span style="color:#86efac">Completed</span>';
        h += ' (' + (d.completed || 0) + '/' + (d.total || 0) + ' volumes)';
      } else {
        h += '<span style="color:#fca5a5">Failed</span>';
      }
      h += '</div>';
      var vols = d.volumes || [];
      if (vols.length > 0) {
        h += '<ul class="dl-volumes">';
        for (var i = 0; i < vols.length; i++) {
          var v = vols[i];
          var icon = v.state === 'done' ? '&#10003; ' : v.state === 'downloading' ? '&#8635; ' : v.state === 'failed' ? '&#10007; ' : '&#8226; ';
          h += '<li class="' + esc(v.state) + '">' + icon + esc(v.name) + '</li>';
        }
        h += '</ul>';
      }
      var errs = d.errors || [];
      if (errs.length > 0) {
        h += '<ul class="dl-errors">';
        for (var i = 0; i < errs.length; i++) h += '<li>' + esc(errs[i]) + '</li>';
        h += '</ul>';
      }
      prog.innerHTML = h;
      if (d.state !== 'running' && polling) { clearInterval(polling); polling = null; }
    }).catch(function() {});
  }
  function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
  update();
  polling = setInterval(update, 5000);
})();
</script>"""

    return _page("Download", "Download", form + history_html, msg, error, scripts)


# --- Schedule page ---

def render_schedule(msg: str = "", error: bool = False) -> str:
    series_map = discover_series()
    state = load_state()
    active_series = load_schedule()

    # Series checkboxes
    all_series = sorted(series_map.keys())
    items = []
    for name in all_series:
        safe = escape(name)
        checked = " checked" if (not active_series or name in active_series) else ""
        count = len(series_map[name])
        items.append(
            f"<li><label>"
            f"<input type='checkbox' name='active' value='{safe}'{checked}>"
            f" {safe} <span style='color:#6b7280'>({count} files)</span>"
            f"</label></li>"
        )
    if not items:
        items_html = "<p class='empty'>No series in upload queue.</p>"
    else:
        items_html = "<ul class='sched-list'>" + "\n".join(items) + "</ul>"

    selection = (
        "<div class='section'>"
        "<h2>Active Series</h2>"
        "<p style='font-size:0.82rem;color:#a0aec0;margin-top:0'>Selected series are delivered first. When all are done, remaining series begin.</p>"
        f"<form method='post' action='/schedule'>"
        f"{items_html}"
        "<div style='margin-top:0.75rem'>"
        "<button type='submit'>Save Selection</button>"
        "</div></form></div>"
    )

    # Preview next 10 deliveries
    preview = simulate_deliveries(series_map, state, active_series, 10)
    if preview:
        prows = []
        for i, p in enumerate(preview, 1):
            prows.append(
                f"<tr>"
                f"<td class='preview-num'>#{i}</td>"
                f"<td>{escape(p['series'])}</td>"
                f"<td>~{p['files']} files</td>"
                f"<td>~{p['pages']} pages</td>"
                f"<td style='color:#6b7280'>{p['remaining_after']} left</td>"
                f"</tr>"
            )
        preview_html = (
            "<div class='section'>"
            "<h2>Expected Next 10 Deliveries</h2>"
            "<p style='font-size:0.82rem;color:#a0aec0;margin-top:0'>Projection based on current queue. Actual deliveries may differ.</p>"
            "<table class='preview-table'><thead><tr>"
            "<th></th><th>Series</th><th>Files</th><th>Size</th><th>Remaining</th>"
            "</tr></thead><tbody>" + "\n".join(prows) + "</tbody></table>"
            "</div>"
        )
    else:
        preview_html = "<div class='section'><h2>Expected Next 10 Deliveries</h2><p class='empty'>No deliveries to preview.</p></div>"

    return _page("Schedule", "Schedule", selection + preview_html, msg, error)


# --- HTTP Handler ---

class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass

    def send_html(self, html: str, status: int = 200):
        body = html.encode()
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_redirect(self, location: str):
        self.send_response(303)
        self.send_header("Location", location)
        self.end_headers()

    def send_json(self, data, status: int = 200):
        body = json.dumps(data, indent=2).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)
        msg = params.get("msg", [""])[0]
        err = params.get("err", ["0"])[0] == "1"

        if parsed.path == "/":
            self.send_html(render_delivery(msg, err))
        elif parsed.path == "/download-page":
            self.send_html(render_download(msg, err))
        elif parsed.path == "/schedule":
            self.send_html(render_schedule(msg, err))
        elif parsed.path == "/api/status":
            series_map = discover_series()
            state = load_state()
            timer = get_timer_info()
            self.send_json({
                "series": {k: len(v) for k, v in series_map.items()},
                "state": state,
                "timer": timer,
            })
        elif parsed.path == "/api/download-status":
            status = read_download_status()
            if status.get("state") == "running" and not is_download_running():
                status["state"] = "failed"
                status["current"] = "Process died unexpectedly"
            self.send_json(status)
        elif parsed.path == "/api/download-history":
            self.send_json(read_download_history())
        else:
            self.send_html("<h1>404</h1>", 404)

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode()
        params = urllib.parse.parse_qs(body)

        if self.path == "/download":
            self._handle_download(params)
        elif self.path == "/deliver":
            self._handle_deliver(params)
        elif self.path == "/schedule":
            self._handle_schedule(params)
        else:
            self.send_html("<h1>404</h1>", 404)

    def _handle_deliver(self, params: dict):
        series = params.get("series", [""])[0].strip()
        user = self.headers.get("Remote-Name") or self.headers.get("Remote-User") or "Unknown"

        if not series:
            self.send_redirect("/?msg=No+series+specified&err=1")
            return

        PENDING_FILE.write_text(series)
        TRIGGER_USER_FILE.write_text(user)

        result = subprocess.run(
            ["systemctl", "start", "manga-scheduler.service"],
            capture_output=True, text=True, timeout=120
        )

        if result.returncode == 0:
            self.send_redirect("/?msg=" + urllib.parse.quote("Delivered: " + series))
        else:
            if PENDING_FILE.exists():
                PENDING_FILE.unlink()
            self.send_redirect("/?msg=" + urllib.parse.quote("Failed: " + result.stderr.strip()) + "&err=1")

    def _handle_download(self, params: dict):
        url = params.get("url", [""])[0].strip()
        series = params.get("series", [""])[0].strip()

        allowed = ("https://tomosmanga.com/", "https://sushiscan.net/")
        if not url or not any(url.startswith(d) for d in allowed):
            self.send_redirect("/download-page?msg=" + urllib.parse.quote("Invalid URL: must be from tomosmanga.com or sushiscan.net") + "&err=1")
            return

        if is_download_running():
            self.send_redirect("/download-page?msg=" + urllib.parse.quote("A download is already in progress.") + "&err=1")
            return

        user = self.headers.get("Remote-Name") or self.headers.get("Remote-User") or "Unknown"
        cmd = [str(DATA_DIR / "venv" / "bin" / "python"), str(DOWNLOADER_SCRIPT), "--url", url, "--user", user]
        if series:
            cmd.extend(["--series", series])

        subprocess.Popen(
            cmd,
            stdout=open(DATA_DIR / "downloader.log", "a"),
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )

        msg = urllib.parse.quote("Download started" + (": " + series if series else ""))
        self.send_redirect("/download-page?msg=" + msg)

    def _handle_schedule(self, params: dict):
        active = params.get("active", [])
        save_schedule(active)
        self.send_redirect("/schedule?msg=" + urllib.parse.quote(f"Schedule updated: {len(active)} series selected"))


if __name__ == "__main__":
    server = http.server.HTTPServer(("127.0.0.1", PORT), Handler)
    print("Manga Scheduler UI listening on 127.0.0.1:" + str(PORT))
    server.serve_forever()
