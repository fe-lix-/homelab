import subprocess
import urllib.parse
import zipfile
from html import escape
from pathlib import Path

import os

UPLOAD_DIR = Path("{{ manga_scheduler_upload_dir }}")
COMICS_DIR = Path("{{ manga_scheduler_comics_dir }}")
DATA_DIR = Path("{{ manga_scheduler_data_dir }}")
STATE_FILE = DATA_DIR / "state.json"
PENDING_FILE = DATA_DIR / "pending.txt"
SCHEDULE_FILE = DATA_DIR / "schedule.json"
SCHEDULER_SCRIPT = DATA_DIR / "manga-scheduler.py"
DOWNLOADER_SCRIPT = DATA_DIR / "manga-downloader.py"
DOWNLOAD_STATUS_FILE = DATA_DIR / "download-status.json"
DOWNLOAD_HISTORY_FILE = DATA_DIR / "download-history.json"
DOWNLOAD_PID_FILE = DATA_DIR / "downloader.pid"
TRIGGER_USER_FILE = DATA_DIR / "trigger-user.txt"
