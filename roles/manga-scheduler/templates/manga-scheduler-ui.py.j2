def _render_delivery_log(runs: list[dict]) -> str:
    if not runs:
        return (
            "  <div class='log-section'>\n"
            "    <h2>Delivery Log</h2>\n"
            "    <p class='empty-log'>No deliveries recorded yet.</p>\n"
            "  </div>\n"
        )
    rows = []
    for run in runs:
        vols = ", ".join(escape(v) for v in run["volumes"]) or "—"
        rows.append(
            "<tr>"
            "<td>" + escape(run["time"]) + "</td>"
            "<td>" + escape(run["series"]) + "</td>"
            "<td class='volumes'>" + vols + "</td>"
            "</tr>"
        )
    return (
        "  <div class='log-section'>\n"
        "    <h2>Delivery Log</h2>\n"
        "    <div class='log-scroll'>\n"
        "      <table>\n"
        "        <thead><tr><th>Time</th><th>Series</th><th>Volumes</th></tr></thead>\n"
        "        <tbody>\n" + "\n".join(rows) + "\n        </tbody>\n"
        "      </table>\n"
        "    </div>\n"
        "  </div>\n"
    )


def render_index(msg: str = "", error: bool = False) -> str:
    series_map = discover_series()
    state = load_state()
    timer = get_timer_info()
    delivery_runs = get_delivery_log()

    series_order = state.get("series_order", [])
    current_index = state.get("current_index", 0)
    next_series = None
    if series_order:
        for offset in range(len(series_order)):
            idx = (current_index + offset) % len(series_order)
            name = series_order[idx]
            if name in series_map:
                next_series = name
                break

    next_run = timer.get("NextElapseUSecRealtime", "n/a")
    last_run = timer.get("LastTriggerUSec", "n/a")

    rows = []
    for name, files in sorted(series_map.items()):
        total_mb = sum(f.stat().st_size for f in files) / (1024 * 1024)
        is_next = "\u2713" if name == next_series else ""
        safe_name = escape(name)
        row_class = ' class="next"' if name == next_series else ""
        rows.append(
            "<tr" + row_class + ">"
            "<td>" + safe_name + "</td>"
            "<td>" + str(len(files)) + "</td>"
            "<td>" + "%.1f MB" % total_mb + "</td>"
            "<td>" + is_next + "</td>"
            "<td>"
            "<form method='post' action='/deliver' onsubmit=\"return confirm('Deliver now: " + safe_name + "?')\">"
            "<input type='hidden' name='series' value='" + safe_name + "'>"
            "<button type='submit'>Deliver Now</button>"
            "</form>"
            "</td>"
            "</tr>"
        )

    rows_html = "\n".join(rows) if rows else "<tr><td colspan='5'>No series in upload queue.</td></tr>"
    msg_html = ""
    if msg:
        cls = "error" if error else "success"
        msg_html = "<div class='" + cls + "'>" + escape(msg) + "</div>"

    return (
        "<!DOCTYPE html>\n"
        "<html lang='en'>\n"
        "<head>\n"
        "  <meta charset='UTF-8'>\n"
        "  <meta name='viewport' content='width=device-width, initial-scale=1'>\n"
        "  <title>Manga Scheduler</title>\n"
        "  <style>" + CSS + "</style>\n"
        "</head>\n"
        "<body>\n"
        "  <h1>Manga Scheduler</h1>\n"
        + msg_html +
        "  <div class='info'>"
        "    <span>Next auto-run: <strong>" + escape(next_run) + "</strong></span>"
        "    <span>Last run: <strong>" + escape(last_run) + "</strong></span>"
        "    <span>Next in queue: <strong>" + escape(next_series or "none") + "</strong></span>"
        "  </div>\n"
        "  <table>\n"
        "    <thead><tr>"
        "<th>Series</th><th>Files</th><th>Size</th><th>Next</th><th>Action</th>"
        "</tr></thead>\n"
        "    <tbody>\n" + rows_html + "\n    </tbody>\n"
        "  </table>\n"
        + _render_delivery_log(delivery_runs) +
        "</body>\n"
        "</html>"
    )


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # suppress default access log noise

    def send_html(self, html: str, status: int = 200):
        body = html.encode()
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_redirect(self, location: str):
        self.send_response(303)
        self.send_header("Location", location)
        self.end_headers()

    def send_json(self, data: dict, status: int = 200):
        body = json.dumps(data, indent=2).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)

        if parsed.path == "/api/status":
            series_map = discover_series()
            state = load_state()
            timer = get_timer_info()
            self.send_json({
                "series": {k: len(v) for k, v in series_map.items()},
                "state": state,
                "timer": timer,
            })
        elif parsed.path == "/":
            msg = params.get("msg", [""])[0]
            err = params.get("err", ["0"])[0] == "1"
            self.send_html(render_index(msg, err))
        else:
            self.send_html("<h1>404</h1>", 404)

    def do_POST(self):
        if self.path != "/deliver":
            self.send_html("<h1>404</h1>", 404)
            return

        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode()
        params = urllib.parse.parse_qs(body)
        series = params.get("series", [""])[0].strip()

        if not series:
            self.send_redirect("/?msg=No+series+specified&err=1")
            return

        # Write pending file so the service delivers this specific series
        PENDING_FILE.write_text(series)

        # Start the service (synchronous for oneshot — waits for completion)
        result = subprocess.run(
            ["systemctl", "start", "manga-scheduler.service"],
            capture_output=True, text=True, timeout=120
        )

        if result.returncode == 0:
            msg = urllib.parse.quote("Delivered: " + series)
            self.send_redirect("/?msg=" + msg)
        else:
            # Clean up pending file if service failed to start
            if PENDING_FILE.exists():
                PENDING_FILE.unlink()
            err_msg = urllib.parse.quote("Failed to deliver '" + series + "': " + result.stderr.strip())
            self.send_redirect("/?msg=" + err_msg + "&err=1")


if __name__ == "__main__":
    server = http.server.HTTPServer(("127.0.0.1", PORT), Handler)
    print("Manga Scheduler UI listening on 127.0.0.1:" + str(PORT))
    server.serve_forever()
