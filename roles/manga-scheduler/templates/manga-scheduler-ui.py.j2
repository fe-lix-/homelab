#!/usr/bin/env python3
"""Manga Scheduler Web UI — manually trigger series delivery ahead of schedule."""

import datetime
import http.server
import json
import re
import subprocess
import urllib.parse
from html import escape
from pathlib import Path

UPLOAD_DIR = Path("{{ manga_scheduler_upload_dir }}")
COMICS_DIR = Path("{{ manga_scheduler_comics_dir }}")
DATA_DIR = Path("{{ manga_scheduler_data_dir }}")
STATE_FILE = DATA_DIR / "state.json"
PENDING_FILE = DATA_DIR / "pending.txt"
SCHEDULER_SCRIPT = DATA_DIR / "manga-scheduler.py"
PORT = {{ manga_scheduler_ui_port }}
{% raw %}
COMIC_EXTENSIONS = {".cbz", ".cbr", ".pdf"}

VOLUME_SUFFIX_RE = re.compile(
    r"\s*-\s*(Tomo|Vol\.?|Volume|Book)\s+\d+.*$", re.IGNORECASE
)
JOURNAL_LINE_RE = re.compile(r"^(\S+)\s+\S+\s+\S+\s+(.+)$")
RUN_START_RE = re.compile(r"^Series: '(.+)' \(\d+ files? remaining\)$")
MOVE_FILE_RE = re.compile(r"^Moving: .+ -> .+/(.+)$")


def series_name_from_file(stem: str) -> str:
    return VOLUME_SUFFIX_RE.sub("", stem).strip()


def discover_series() -> dict:
    """Return {series_name: [path, ...]} for files in UPLOAD_DIR."""
    series: dict = {}
    if not UPLOAD_DIR.is_dir():
        return series
    for entry in sorted(UPLOAD_DIR.iterdir()):
        if entry.is_dir():
            files = sorted(
                f for f in entry.iterdir()
                if f.is_file() and f.suffix.lower() in COMIC_EXTENSIONS
            )
            if files:
                series[entry.name] = files
        elif entry.is_file() and entry.suffix.lower() in COMIC_EXTENSIONS:
            name = series_name_from_file(entry.stem)
            series.setdefault(name, []).append(entry)
    for name in series:
        series[name] = sorted(series[name])
    return series


def load_state() -> dict:
    if STATE_FILE.exists():
        with STATE_FILE.open() as f:
            return json.load(f)
    return {"series_order": [], "current_index": 0}


def get_delivery_log(lines: int = 500) -> list[dict]:
    """Return parsed delivery runs from the systemd journal, newest first."""
    try:
        result = subprocess.run(
            ["journalctl", "-u", "manga-scheduler.service",
             "--no-pager", "-n", str(lines), "-o", "short-iso"],
            capture_output=True, text=True, timeout=5
        )
        raw = result.stdout.strip()
    except Exception:
        return []

    runs = []
    current: dict | None = None

    for line in raw.splitlines():
        m = JOURNAL_LINE_RE.match(line)
        if not m:
            continue
        timestamp_str, message = m.group(1), m.group(2)

        series_m = RUN_START_RE.match(message)
        if series_m:
            if current:
                runs.append(current)
            try:
                dt = datetime.datetime.fromisoformat(timestamp_str)
                formatted = dt.strftime("%Y-%m-%d %H:%M")
            except Exception:
                formatted = timestamp_str
            current = {"time": formatted, "series": series_m.group(1), "volumes": []}
            continue

        if current is None:
            continue

        move_m = MOVE_FILE_RE.match(message)
        if move_m:
            current["volumes"].append(move_m.group(1))

    if current:
        runs.append(current)

    runs.reverse()
    return runs


def get_timer_info() -> dict:
    """Get next/last run info from systemd."""
    try:
        result = subprocess.run(
            ["systemctl", "show", "manga-scheduler.timer",
             "--property=NextElapseUSecRealtime,LastTriggerUSec,ActiveState"],
            capture_output=True, text=True, timeout=5
        )
        props = {}
        for line in result.stdout.strip().splitlines():
            k, _, v = line.partition("=")
            props[k] = v
        return props
    except Exception:
        return {}


