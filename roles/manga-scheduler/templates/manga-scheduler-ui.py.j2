def _render_delivery_log(runs: list[dict]) -> str:
    if not runs:
        return (
            "  <div class='log-section'>\n"
            "    <h2>Delivery Log</h2>\n"
            "    <p class='empty-log'>No deliveries recorded yet.</p>\n"
            "  </div>\n"
        )
    rows = []
    for run in runs:
        vols = ", ".join(escape(v) for v in run["volumes"]) or "—"
        rows.append(
            "<tr>"
            "<td>" + escape(run["time"]) + "</td>"
            "<td>" + escape(run["series"]) + "</td>"
            "<td class='volumes'>" + vols + "</td>"
            "</tr>"
        )
    return (
        "  <div class='log-section'>\n"
        "    <h2>Delivery Log</h2>\n"
        "    <div class='log-scroll'>\n"
        "      <table>\n"
        "        <thead><tr><th>Time</th><th>Series</th><th>Volumes</th></tr></thead>\n"
        "        <tbody>\n" + "\n".join(rows) + "\n        </tbody>\n"
        "      </table>\n"
        "    </div>\n"
        "  </div>\n"
    )


def _render_download_section() -> str:
    """Render the download form + active progress section."""
    running = is_download_running()
    status = read_download_status()

    html = "  <div class='dl-section'>\n    <h2>Manga Downloader</h2>\n"

    if running:
        html += (
            "    <form class='dl-form'>\n"
            "      <div><label>URL</label><br>"
            "<input type='text' name='url' disabled placeholder='Download in progress...'></div>\n"
            "      <div><label>Series name</label><br>"
            "<input type='text' name='series' disabled></div>\n"
            "      <button type='submit' disabled>Downloading...</button>\n"
            "    </form>\n"
        )
    else:
        html += (
            "    <form class='dl-form' method='post' action='/download'>\n"
            "      <div><label>URL</label><br>"
            "<input type='text' name='url' placeholder='https://tomosmanga.com/... or https://sushiscan.net/...' required></div>\n"
            "      <div><label>Series name (optional)</label><br>"
            "<input type='text' name='series' placeholder='Auto-detect'></div>\n"
            "      <button type='submit'>Start Download</button>\n"
            "    </form>\n"
        )

    # Progress area (populated by JS when running)
    html += "    <div id='dl-progress' class='dl-progress'></div>\n"
    html += "  </div>\n"

    # JavaScript for polling
    html += """  <script>
  (function() {
    var prog = document.getElementById('dl-progress');
    var polling = null;
    function update() {
      fetch('/api/download-status').then(function(r) { return r.json(); }).then(function(d) {
        if (d.state === 'idle') { prog.innerHTML = ''; return; }
        var h = '<div class="status-line">Series: <strong>' + esc(d.series || '') + '</strong> &mdash; ';
        if (d.state === 'running') {
          h += '<span style="color:#fbbf24">' + esc(d.current || '') + '</span>';
          h += ' (' + (d.completed || 0) + '/' + (d.total || 0) + ' volumes)';
        } else if (d.state === 'completed') {
          h += '<span style="color:#86efac">Completed</span>';
          h += ' (' + (d.completed || 0) + '/' + (d.total || 0) + ' volumes)';
        } else {
          h += '<span style="color:#fca5a5">Failed</span>';
        }
        h += '</div>';
        var vols = d.volumes || [];
        if (vols.length > 0) {
          h += '<ul class="dl-volumes">';
          for (var i = 0; i < vols.length; i++) {
            var v = vols[i];
            var icon = v.state === 'done' ? '&#10003; ' : v.state === 'downloading' ? '&#8635; ' : v.state === 'failed' ? '&#10007; ' : '&#8226; ';
            h += '<li class="' + esc(v.state) + '">' + icon + esc(v.name) + '</li>';
          }
          h += '</ul>';
        }
        var errs = d.errors || [];
        if (errs.length > 0) {
          h += '<ul class="dl-errors">';
          for (var i = 0; i < errs.length; i++) h += '<li>' + esc(errs[i]) + '</li>';
          h += '</ul>';
        }
        prog.innerHTML = h;
        if (d.state !== 'running' && polling) { clearInterval(polling); polling = null; }
      }).catch(function() {});
    }
    function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    update();
    polling = setInterval(update, 5000);
  })();
  </script>
"""
    return html


def _render_download_history() -> str:
    """Render the download history table."""
    history = read_download_history()
    if not history:
        return (
            "  <div class='dl-history'>\n"
            "    <h2>Download History</h2>\n"
            "    <p class='empty-log'>No downloads yet.</p>\n"
            "  </div>\n"
        )
    running = is_download_running()
    rows = []
    for entry in reversed(history):
        started = entry.get("started", "")
        try:
            dt = datetime.datetime.fromisoformat(started)
            started = dt.strftime("%Y-%m-%d %H:%M")
        except Exception:
            pass
        state = entry.get("state", "unknown")
        result_class = "result-completed" if state == "completed" else "result-failed"
        count = str(entry.get("completed", 0)) + "/" + str(entry.get("total", 0))
        errs = ", ".join(entry.get("errors", [])) or "-"
        retry_html = ""
        if state != "completed" and entry.get("url") and not running:
            safe_url = escape(entry.get("url", ""))
            safe_series = escape(entry.get("series", ""))
            retry_html = (
                "<form method='post' action='/download' style='display:inline'>"
                "<input type='hidden' name='url' value='" + safe_url + "'>"
                "<input type='hidden' name='series' value='" + safe_series + "'>"
                "<button type='submit' class='retry-btn'>Retry</button>"
                "</form>"
            )
        rows.append(
            "<tr>"
            "<td>" + escape(started) + "</td>"
            "<td>" + escape(entry.get("series", "")) + "</td>"
            "<td class='" + result_class + "'>" + escape(state) + "</td>"
            "<td>" + escape(count) + "</td>"
            "<td class='errors'>" + escape(errs) + "</td>"
            "<td>" + retry_html + "</td>"
            "</tr>"
        )
    return (
        "  <div class='dl-history'>\n"
        "    <h2>Download History</h2>\n"
        "    <div class='log-scroll'>\n"
        "      <table>\n"
        "        <thead><tr><th>Date</th><th>Series</th><th>Result</th><th>Volumes</th><th>Errors</th><th></th></tr></thead>\n"
        "        <tbody>\n" + "\n".join(rows) + "\n        </tbody>\n"
        "      </table>\n"
        "    </div>\n"
        "  </div>\n"
    )


def render_index(msg: str = "", error: bool = False) -> str:
    series_map = discover_series()
    state = load_state()
    timer = get_timer_info()
    delivery_runs = get_delivery_log()

    series_order = state.get("series_order", [])
    current_index = state.get("current_index", 0)
    next_series = None
    if series_order:
        for offset in range(len(series_order)):
            idx = (current_index + offset) % len(series_order)
            name = series_order[idx]
            if name in series_map:
                next_series = name
                break

    next_run = timer.get("NextElapseUSecRealtime", "n/a")
    last_run = timer.get("LastTriggerUSec", "n/a")

    rows = []
    for name, files in sorted(series_map.items()):
        total_mb = sum(f.stat().st_size for f in files) / (1024 * 1024)
        is_next = "\u2713" if name == next_series else ""
        safe_name = escape(name)
        row_class = ' class="next"' if name == next_series else ""
        rows.append(
            "<tr" + row_class + ">"
            "<td>" + safe_name + "</td>"
            "<td>" + str(len(files)) + "</td>"
            "<td>" + "%.1f MB" % total_mb + "</td>"
            "<td>" + is_next + "</td>"
            "<td>"
            "<form method='post' action='/deliver' onsubmit=\"return confirm('Deliver now: " + safe_name + "?')\">"
            "<input type='hidden' name='series' value='" + safe_name + "'>"
            "<button type='submit'>Deliver Now</button>"
            "</form>"
            "</td>"
            "</tr>"
        )

    rows_html = "\n".join(rows) if rows else "<tr><td colspan='5'>No series in upload queue.</td></tr>"
    msg_html = ""
    if msg:
        cls = "error" if error else "success"
        msg_html = "<div class='" + cls + "'>" + escape(msg) + "</div>"

    return (
        "<!DOCTYPE html>\n"
        "<html lang='en'>\n"
        "<head>\n"
        "  <meta charset='UTF-8'>\n"
        "  <meta name='viewport' content='width=device-width, initial-scale=1'>\n"
        "  <title>Manga Scheduler</title>\n"
        "  <style>" + CSS + "</style>\n"
        "</head>\n"
        "<body>\n"
        "  <h1>Manga Scheduler</h1>\n"
        + msg_html +
        "  <div class='info'>"
        "    <span>Next auto-run: <strong>" + escape(next_run) + "</strong></span>"
        "    <span>Last run: <strong>" + escape(last_run) + "</strong></span>"
        "    <span>Next in queue: <strong>" + escape(next_series or "none") + "</strong></span>"
        "  </div>\n"
        + _render_download_section() +
        "  <table>\n"
        "    <thead><tr>"
        "<th>Series</th><th>Files</th><th>Size</th><th>Next</th><th>Action</th>"
        "</tr></thead>\n"
        "    <tbody>\n" + rows_html + "\n    </tbody>\n"
        "  </table>\n"
        + _render_delivery_log(delivery_runs) +
        _render_download_history() +
        "</body>\n"
        "</html>"
    )


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # suppress default access log noise

    def send_html(self, html: str, status: int = 200):
        body = html.encode()
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_redirect(self, location: str):
        self.send_response(303)
        self.send_header("Location", location)
        self.end_headers()

    def send_json(self, data: dict, status: int = 200):
        body = json.dumps(data, indent=2).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        params = urllib.parse.parse_qs(parsed.query)

        if parsed.path == "/api/status":
            series_map = discover_series()
            state = load_state()
            timer = get_timer_info()
            self.send_json({
                "series": {k: len(v) for k, v in series_map.items()},
                "state": state,
                "timer": timer,
            })
        elif parsed.path == "/api/download-status":
            status = read_download_status()
            # If status says running but process is dead, mark as failed
            if status.get("state") == "running" and not is_download_running():
                status["state"] = "failed"
                status["current"] = "Process died unexpectedly"
            self.send_json(status)
        elif parsed.path == "/api/download-history":
            self.send_json(read_download_history())
        elif parsed.path == "/":
            msg = params.get("msg", [""])[0]
            err = params.get("err", ["0"])[0] == "1"
            self.send_html(render_index(msg, err))
        else:
            self.send_html("<h1>404</h1>", 404)

    def do_POST(self):
        length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(length).decode()
        params = urllib.parse.parse_qs(body)

        if self.path == "/download":
            self._handle_download(params)
            return

        if self.path != "/deliver":
            self.send_html("<h1>404</h1>", 404)
            return

        series = params.get("series", [""])[0].strip()
        user = self.headers.get("Remote-Name") or self.headers.get("Remote-User") or "Unknown"

        if not series:
            self.send_redirect("/?msg=No+series+specified&err=1")
            return

        # Write pending file so the service delivers this specific series
        PENDING_FILE.write_text(series)
        TRIGGER_USER_FILE.write_text(user)

        # Start the service (synchronous for oneshot — waits for completion)
        result = subprocess.run(
            ["systemctl", "start", "manga-scheduler.service"],
            capture_output=True, text=True, timeout=120
        )

        if result.returncode == 0:
            msg = urllib.parse.quote("Delivered: " + series)
            self.send_redirect("/?msg=" + msg)
        else:
            # Clean up pending file if service failed to start
            if PENDING_FILE.exists():
                PENDING_FILE.unlink()
            err_msg = urllib.parse.quote("Failed to deliver '" + series + "': " + result.stderr.strip())
            self.send_redirect("/?msg=" + err_msg + "&err=1")


    def _handle_download(self, params: dict):
        url = params.get("url", [""])[0].strip()
        series = params.get("series", [""])[0].strip()

        allowed = ("https://tomosmanga.com/", "https://sushiscan.net/")
        if not url or not any(url.startswith(d) for d in allowed):
            self.send_redirect("/?msg=" + urllib.parse.quote("Invalid URL: must be from tomosmanga.com or sushiscan.net") + "&err=1")
            return

        if is_download_running():
            self.send_redirect("/?msg=" + urllib.parse.quote("A download is already in progress.") + "&err=1")
            return

        user = self.headers.get("Remote-Name") or self.headers.get("Remote-User") or "Unknown"
        cmd = [str(DATA_DIR / "venv" / "bin" / "python"), str(DOWNLOADER_SCRIPT), "--url", url, "--user", user]
        if series:
            cmd.extend(["--series", series])

        subprocess.Popen(
            cmd,
            stdout=open(DATA_DIR / "downloader.log", "a"),
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )

        msg = urllib.parse.quote("Download started" + (": " + series if series else ""))
        self.send_redirect("/?msg=" + msg)


if __name__ == "__main__":
    server = http.server.HTTPServer(("127.0.0.1", PORT), Handler)
    print("Manga Scheduler UI listening on 127.0.0.1:" + str(PORT))
    server.serve_forever()
