_log_lines = []


def log(message: str, transient: bool = False):
    """Print a log message and track it for status updates."""
    print(message, flush=True)
    if not transient:
        _log_lines.append(message)


# --- PID management ---

def check_already_running() -> bool:
    if not PID_FILE.exists():
        return False
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError):
        PID_FILE.unlink(missing_ok=True)
        return False


def write_pid():
    PID_FILE.write_text(str(os.getpid()))


def remove_pid():
    PID_FILE.unlink(missing_ok=True)


# --- Sushiscan pipeline ---

SUSHISCAN_CHAPTER_RE = re.compile(
    r'<li data-num="([^"]+)"[^>]*><div class="chbox"><div class="eph-num">\s*'
    r'<a href="([^"]+)">\s*'
    r'<span class="chapternum">\s*([^<]+)</span>\s*'
    r'<span class="chapterdate">([^<]+)</span>',
)
SUSHISCAN_TS_READER_RE = re.compile(r'ts_reader\.run\(({.+?})\)')
SUSHISCAN_USER_AGENT = "Mozilla/5.0 (X11; Linux x86_64; rv:149.0) Gecko/20100101 Firefox/149.0"


def sushiscan_series_name_from_url(url: str) -> str:
    """Extract series name from sushiscan catalogue URL."""
    path = urllib.parse.urlparse(url).path.strip("/")
    slug = path.split("/")[-1] if "/" in path else path
    # Strip leading number prefix: "1-latelier-des-sorciers" -> "latelier-des-sorciers"
    slug = re.sub(r"^\d+-", "", slug)
    return slug.replace("-", " ").title()


def sushiscan_parse_entries(html: str) -> list[dict]:
    """Parse chapter/volume list from sushiscan catalogue page.
    Returns list of {name, number, url, date} dicts, ordered oldest-first."""
    entries = []
    for data_num, url, name, date in SUSHISCAN_CHAPTER_RE.findall(html):
        entries.append({
            "name": name.strip(),
            "number": data_num.strip(),
            "url": url.strip(),
            "date": date.strip(),
        })
    entries.reverse()  # catalogue lists newest first; we want oldest first
    return entries


def sushiscan_parse_pages(html: str, entry_url: str = "") -> list[str]:
    """Extract image URLs from a sushiscan reader page via ts_reader.run() JSON."""
    match = SUSHISCAN_TS_READER_RE.search(html)
    if not match:
        # Dump first 2000 chars for debugging
        log(f"DEBUG: ts_reader not found in page. HTML starts with: {html[:2000]}")
        raise RuntimeError(f"ts_reader.run() not found in page ({entry_url})")
    data = json.loads(match.group(1))
    sources = data.get("sources", [])
    if not sources:
        log(f"DEBUG: ts_reader data has no sources: {json.dumps(data)[:500]}")
        raise RuntimeError(f"No sources in ts_reader data ({entry_url})")
    images = sources[0].get("images", [])
    if not images:
        raise RuntimeError(f"No images in ts_reader source ({entry_url})")
    log(f"  First image: {images[0][:80]}")
    return images


def sushiscan_build_cookie_header(cookies: list[dict]) -> str:
    """Build a Cookie header string from ByParr's cookie list."""
    parts = []
    for c in cookies:
        name = c.get("name", "")
        value = c.get("value", "")
        if name:
            parts.append(f"{name}={value}")
    return "; ".join(parts)


def sushiscan_download_image(url: str, cookie_header: str, user_agent: str, timeout: int = 30) -> bytes:
    """Download a single image from sushiscan CDN with Cloudflare cookies."""
    req = urllib.request.Request(url, headers={
        "User-Agent": user_agent,
        "Accept": "image/avif,image/webp,image/png,image/svg+xml,image/*;q=0.8,*/*;q=0.5",
        "Accept-Language": "en-US,en;q=0.9",
        "Referer": "https://sushiscan.net/",
        "Cookie": cookie_header,
    })
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return resp.read()


def sushiscan_make_comicinfo(series_name: str, entry: dict, page_count: int) -> str:
    """Generate ComicInfo.xml for a sushiscan chapter/volume."""
    number = entry["number"]
    name = entry["name"]
    # Detect if volume or chapter
    is_volume = "volume" in name.lower()
    lines = [
        '<?xml version="1.0" encoding="UTF-8"?>',
        '<ComicInfo xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">',
        f'\t<Series>{series_name}</Series>',
    ]
    if is_volume:
        # Extract volume number
        vol_num = re.search(r"\d+(?:\.\d+)?", number)
        if vol_num:
            lines.append(f'\t<Volume>{vol_num.group()}</Volume>')
    else:
        # Chapter number
        ch_num = re.search(r"\d+(?:\.\d+)?", number)
        if ch_num:
            lines.append(f'\t<Number>{ch_num.group()}</Number>')
    lines.extend([
        f'\t<Title>{name}</Title>',
        f'\t<PageCount>{page_count}</PageCount>',
        '\t<LanguageISO>fr</LanguageISO>',
        '\t<Manga>YesAndRightToLeft</Manga>',
        '</ComicInfo>',
    ])
    return "\n".join(lines)


def sushiscan_download_entry(entry: dict, series_name: str, dest_dir: Path) -> Path:
    """Download all pages for a sushiscan entry and create a CBZ.
    Uses a staging directory to persist pages across retries.
    Returns path to the created .cbz file."""
    name = entry["name"]
    entry_url = entry["url"]

    # Staging dir persists pages across retries
    safe_name = re.sub(r'[^\w\s-]', '_', name)
    staging_dir = STAGING_DIR / "sushiscan" / safe_name
    staging_dir.mkdir(parents=True, exist_ok=True)

    log(f"Fetching reader page: {entry_url}")
    sol = byparr_request(entry_url)
    html = sol.get("response", "")
    final_url = sol.get("url", entry_url)
    cookies = sol.get("cookies", [])
    user_agent = sol.get("userAgent", SUSHISCAN_USER_AGENT)
    cookie_header = sushiscan_build_cookie_header(cookies)
    if final_url != entry_url:
        log(f"  Redirected to: {final_url}")
    log(f"  Page HTML size: {len(html)} bytes, cookies: {len(cookies)}")
    images = sushiscan_parse_pages(html, entry_url)
    total_pages = len(images)
    log(f"  Found {total_pages} page(s)")

    # Save image URL list so retries use the same mapping
    urls_file = staging_dir / "pages.json"
    urls_file.write_text(json.dumps(images))

    # Download pages, skipping those already in staging
    failed_pages = []
    for i, img_url in enumerate(images, 1):
        ext = os.path.splitext(urllib.parse.urlparse(img_url).path)[1] or ".webp"
        page_name = f"{i:03d}{ext}"
        page_path = staging_dir / page_name

        if page_path.exists() and page_path.stat().st_size >= 10240:
            log(f"  Page {i}/{total_pages} — cached", transient=True)
            continue

        log(f"  Page {i}/{total_pages} — downloading", transient=True)
        try:
            img_data = sushiscan_download_image(img_url, cookie_header, user_agent)
            if len(img_data) < 10240:
                log(f"  WARNING: Page {i} only {len(img_data)} bytes from {img_url}")
                failed_pages.append(i)
                continue
            page_path.write_bytes(img_data)
        except Exception as exc:
            log(f"  Page {i} failed: {exc}")
            failed_pages.append(i)
            continue

        time.sleep(0.3)

    if failed_pages:
        raise RuntimeError(
            f"{len(failed_pages)}/{total_pages} page(s) failed: {failed_pages}. "
            f"Retry to re-attempt only the missing pages."
        )

    # All pages present — build CBZ
    cbz_name = f"{name}.cbz"
    cbz_path = dest_dir / cbz_name
    dest_dir.mkdir(parents=True, exist_ok=True)

    buf = io.BytesIO()
    with zipfile.ZipFile(buf, "w", zipfile.ZIP_STORED) as zf:
        for i in range(1, total_pages + 1):
            # Find the page file (could be .jpg, .webp, .png)
            matches = list(staging_dir.glob(f"{i:03d}.*"))
            matches = [m for m in matches if m.suffix != ".json"]
            if not matches:
                raise RuntimeError(f"Page {i} missing from staging after download")
            page_path = matches[0]
            zf.writestr(page_path.name, page_path.read_bytes())

        comicinfo = sushiscan_make_comicinfo(series_name, entry, total_pages)
        zf.writestr("ComicInfo.xml", comicinfo.encode("utf-8"))

    with cbz_path.open("wb") as f:
        f.write(buf.getvalue())

    # Clean up staging for this entry
    shutil.rmtree(staging_dir)

    log(f"Created: {cbz_name} ({total_pages} pages, {len(buf.getvalue()) // 1024}KB)")
    return cbz_path


def run_sushiscan_pipeline(args, series: str, started: str, prev_status):
    """Sushiscan download pipeline: catalogue → entries → images → CBZ."""
    errors = []
    completed_count = 0
    total_count = 0
    volumes = []

    try:
        update_status(
            state="running", url=args.url, series=series,
            total=0, completed=0, current="Fetching catalogue...",
            volumes=[], errors=[], pid=os.getpid(),
        )

        log(f"Fetching catalogue: {args.url}")
        html, final_url = byparr_html(args.url)
        if final_url != args.url:
            log(f"Redirected to: {final_url}")
        log(f"Catalogue HTML size: {len(html)} bytes")

        entries = sushiscan_parse_entries(html)
        total_count = len(entries)
        if not entries:
            log(f"DEBUG: No entries found. HTML starts with: {html[:2000]}")
            raise RuntimeError("No chapters/volumes found on the page.")
        log(f"Found {total_count} entry(ies):")
        for e in entries:
            log(f"  {e['name']} — {e['url']}")

        volumes = [{"name": e["name"], "state": "pending"} for e in entries]

        # Retry: skip already-completed entries
        previously_done = set()
        if (prev_status
                and prev_status.get("url") == args.url
                and prev_status.get("series") == series):
            for idx, vol in enumerate(prev_status.get("volumes", [])):
                if vol.get("state") == "done" and idx < total_count:
                    previously_done.add(idx)
                    volumes[idx]["state"] = "done"
                    completed_count += 1
            if previously_done:
                log(f"Retry: skipping {len(previously_done)} already-completed entry(ies)")

        update_status(total=total_count, completed=completed_count, volumes=volumes)

        series_dir = UPLOAD_DIR / series

        for i, entry in enumerate(entries):
            if i in previously_done:
                log(f"Skipping {entry['name']} (already downloaded)")
                continue

            entry_label = f"{entry['name']} ({i+1}/{total_count})"
            volumes[i]["state"] = "downloading"
            update_status(
                completed=completed_count, current=f"Downloading {entry_label}",
                volumes=volumes,
            )

            try:
                cbz_path = sushiscan_download_entry(entry, series, series_dir)
                volumes[i]["name"] = cbz_path.name
                volumes[i]["state"] = "done"
                completed_count += 1
                update_status(completed=completed_count, volumes=volumes)
            except Exception as e:
                tb = traceback.format_exc()
                err_msg = f"{entry_label}: {e}"
                log(f"ERROR: {err_msg}")
                log(f"Traceback:\n{tb}")
                errors.append(err_msg)
                volumes[i]["state"] = "failed"
                update_status(errors=errors, volumes=volumes)

            if i < total_count - 1:
                log(f"Waiting {DELAY}s before next download...")
                time.sleep(DELAY)

        final_state = "completed" if completed_count == total_count else "failed"
        log(f"Done: {completed_count}/{total_count} entries for '{series}'")
        update_status(state=final_state, current="Done")

        if final_state == "completed":
            notify(f"✅ {series}",
                   f"Downloaded {completed_count}/{total_count} entry(ies)\nTriggered by: {args.user}",
                   tags="white_check_mark")
        else:
            failed = [v["name"] for v in volumes if v["state"] == "failed"]
            notify(f"⚠️ {series}",
                   f"{completed_count}/{total_count} entry(ies)\nFailed: {', '.join(failed)}\nTriggered by: {args.user}",
                   tags="warning", priority="high")

    except Exception as e:
        tb = traceback.format_exc()
        log(f"FATAL: {e}")
        log(f"Traceback:\n{tb}")
        errors.append(str(e))
        update_status(state=final_state if "final_state" in dir() else "failed", current=str(e), errors=errors)
        final_state = "failed"
        notify(f"❌ {series}", f"Download failed: {e}\nTriggered by: {args.user}",
               tags="x", priority="high")

    finally:
        remove_pid()
        append_history({
            "url": args.url, "series": series, "started": started,
            "finished": datetime.now(timezone.utc).isoformat(),
            "state": final_state if "final_state" in dir() else "failed",
            "total": total_count, "completed": completed_count, "errors": errors,
        })


# --- Main ---

def main():
    parser = argparse.ArgumentParser(description="Download manga")
    parser.add_argument("--url", required=True, help="Series URL (tomosmanga.com or sushiscan.net)")
    parser.add_argument("--series", default="", help="Override series name")
    parser.add_argument("--user", default="Unknown", help="Name of the user who triggered the download")
    args = parser.parse_args()

    if check_already_running():
        print("ERROR: Another download is already running.", file=sys.stderr)
        sys.exit(1)

    # Detect source and derive series name
    is_sushiscan = "sushiscan.net" in args.url
    if args.series.strip():
        series = args.series.strip()
    elif is_sushiscan:
        series = sushiscan_series_name_from_url(args.url)
    else:
        series = series_name_from_url(args.url)
    started = datetime.now(timezone.utc).isoformat()

    # Handle signals for clean shutdown
    def handle_signal(signum, _frame):
        update_status(state="failed", current="Interrupted by signal")
        append_history({
            "url": args.url, "series": series, "started": started,
            "finished": datetime.now(timezone.utc).isoformat(),
            "state": "failed", "total": 0, "completed": 0,
            "errors": ["Interrupted by signal"],
        })
        remove_pid()
        sys.exit(1)

    signal.signal(signal.SIGTERM, handle_signal)

    write_pid()

    # Read previous status before overwriting (needed for retry skip logic)
    prev_status = None
    if STATUS_FILE.exists():
        try:
            prev_status = json.loads(STATUS_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass

    if is_sushiscan:
        run_sushiscan_pipeline(args, series, started, prev_status)
        return

    # --- tomosmanga.com pipeline ---
    errors = []
    completed_count = 0
    total_count = 0
    volumes = []

    try:
        update_status(
            state="running", url=args.url, series=series,
            total=0, completed=0, current="Fetching page...",
            volumes=[], errors=[], pid=os.getpid(),
        )

        # Step 1: Fetch the tomosmanga page
        log(f"Fetching: {args.url}")
        html, _ = byparr_html(args.url)

        # Step 2: Parse ouo.io links
        ouo_links = parse_ouo_links(html)
        total_count = len(ouo_links)
        if not ouo_links:
            raise RuntimeError("No ouo.io download links found on the page.")
        log(f"Found {total_count} download link(s)")

        volumes = [{"name": f"Volume {i+1}", "state": "pending"} for i in range(total_count)]

        # Check previous status to skip already-completed volumes on retry
        previously_done = set()
        if (prev_status
                and prev_status.get("url") == args.url
                and prev_status.get("series") == series):
            for idx, vol in enumerate(prev_status.get("volumes", [])):
                if vol.get("state") == "done" and idx < total_count:
                    previously_done.add(idx)
                    volumes[idx]["name"] = vol.get("name", f"Volume {idx+1}")
                    volumes[idx]["state"] = "done"
                    completed_count += 1
            if previously_done:
                log(f"Retry: skipping {len(previously_done)} already-completed volume(s)")

        update_status(total=total_count, completed=completed_count, volumes=volumes)

        series_dir = UPLOAD_DIR / series

        # Step 3: Sequential download loop
        for i, ouo_url in enumerate(ouo_links):
            if i in previously_done:
                log(f"Skipping Volume {i+1}/{total_count} (already downloaded)")
                continue

            vol_label = f"Volume {i+1}/{total_count}"
            volumes[i]["state"] = "downloading"
            update_status(
                completed=completed_count, current=f"Resolving {vol_label}",
                volumes=volumes,
            )

            try:
                cleanup_staging()

                # Resolve ouo.io -> Fireload URL
                fireload_url = resolve_ouo_link(ouo_url)
                volumes[i]["name"] = f"Volume {i+1}"
                update_status(current=f"Downloading {vol_label}", volumes=volumes)

                # Download from Fireload (handles countdown + download in browser)
                archive_path = download_from_fireload(fireload_url, STAGING_DIR)
                volumes[i]["name"] = archive_path.name

                # Extract
                update_status(current=f"Extracting {vol_label}", volumes=volumes)
                extract_dir = STAGING_DIR / "extracted"
                comic_files = extract_archive(archive_path, extract_dir)

                if not comic_files:
                    raise RuntimeError("No comic files found in archive")

                # Move to upload dir
                move_comic_files(comic_files, series_dir)
                volumes[i]["state"] = "done"
                completed_count += 1
                update_status(completed=completed_count, volumes=volumes)

            except Exception as e:
                tb = traceback.format_exc()
                err_msg = f"{vol_label}: {e}"
                log(f"ERROR: {err_msg}")
                log(f"Traceback:\n{tb}")
                errors.append(err_msg)
                volumes[i]["state"] = "failed"
                update_status(errors=errors, volumes=volumes)

            # Delay between downloads (except after the last one)
            if i < total_count - 1:
                log(f"Waiting {DELAY}s before next download...")
                time.sleep(DELAY)

        final_state = "completed" if completed_count == total_count else "failed"
        log(f"Done: {completed_count}/{total_count} volumes downloaded for '{series}'")
        update_status(state=final_state, current="Done")

        if final_state == "completed":
            notify(
                f"✅ {series}",
                f"Downloaded {completed_count}/{total_count} volume(s)\n"
                f"Triggered by: {args.user}",
                tags="white_check_mark",
            )
        else:
            failed_vols = [v["name"] for v in volumes if v["state"] == "failed"]
            notify(
                f"⚠️ {series}",
                f"{completed_count}/{total_count} volume(s) downloaded\n"
                f"Failed: {', '.join(failed_vols)}\n"
                f"Triggered by: {args.user}",
                tags="warning",
                priority="high",
            )

    except Exception as e:
        tb = traceback.format_exc()
        log(f"FATAL: {e}")
        log(f"Traceback:\n{tb}")
        errors.append(str(e))
        update_status(state="failed", current=str(e), errors=errors)
        final_state = "failed"
        notify(
            f"❌ {series}",
            f"Download failed: {e}\n"
            f"Triggered by: {args.user}",
            tags="x",
            priority="high",
        )

    finally:
        cleanup_staging()
        remove_pid()
        append_history({
            "url": args.url,
            "series": series,
            "started": started,
            "finished": datetime.now(timezone.utc).isoformat(),
            "state": final_state if "final_state" in dir() else "failed",
            "total": total_count,
            "completed": completed_count,
            "errors": errors,
        })


if __name__ == "__main__":
    main()
