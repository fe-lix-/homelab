[Unit]
Description=Manga Scheduler — move next series batch to Komga
After=network.target

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 {{ manga_scheduler_data_dir }}/manga-scheduler.py
Nice=19
IOSchedulingClass=idle
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths={{ manga_scheduler_data_dir }} {{ manga_scheduler_upload_dir }} {{ manga_scheduler_comics_dir }}
