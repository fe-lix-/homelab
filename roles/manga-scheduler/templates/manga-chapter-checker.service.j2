[Unit]
Description=Manga Chapter Checker — poll for new chapters via gallery-dl
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart={{ manga_scheduler_data_dir }}/venv/bin/python {{ manga_scheduler_data_dir }}/manga-chapter-checker.py
Nice=19
IOSchedulingClass=idle
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths={{ manga_scheduler_data_dir }} {{ manga_scheduler_comics_dir }}
