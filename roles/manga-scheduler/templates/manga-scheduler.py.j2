#!/usr/bin/env python3
"""Manga Scheduler — drip-feed manga series from uploads into Komga library."""

import argparse
import json
import os
import re
import shutil
import sys
import urllib.error
import urllib.request
from base64 import b64encode
from pathlib import Path

UPLOAD_DIR = Path("{{ manga_scheduler_upload_dir }}")
COMICS_DIR = Path("{{ manga_scheduler_comics_dir }}")
DATA_DIR = Path("{{ manga_scheduler_data_dir }}")
TARGET_BYTES = {{ manga_scheduler_target_mb }} * 1024 * 1024
STATE_FILE = DATA_DIR / "state.json"
PENDING_FILE = DATA_DIR / "pending.txt"
TRIGGER_USER_FILE = DATA_DIR / "trigger-user.txt"
SCHEDULE_FILE = DATA_DIR / "schedule.json"
KOMGA_URL = "http://127.0.0.1:{{ komga_port }}"
KOMGA_USER = "{{ komga_admin_email }}"
KOMGA_PASSWORD = "{{ komga_admin_password }}"
NTFY_URL = "{{ manga_scheduler_ntfy_url }}"
NTFY_TOPIC = "{{ manga_scheduler_ntfy_topic }}"
NTFY_TOKEN = "{{ manga_scheduler_ntfy_token }}"

VOLUME_SUFFIX_RE = re.compile(
    r"\s*-\s*(Tomo|Vol\.?|Volume|Book)\s+\d+.*$", re.IGNORECASE
)
COMIC_EXTENSIONS = {".cbz", ".cbr", ".pdf"}


def series_name_from_file(stem: str) -> str:
    """Extract series name from a file stem by stripping volume suffix."""
    return VOLUME_SUFFIX_RE.sub("", stem).strip()


def discover_series(upload_dir: Path) -> dict[str, list[Path]]:
    """
    Return a mapping of series_name -> sorted list of file paths.
    Directory-based: each subdir is a series.
    File-based: top-level comic files grouped by regex-extracted series name.
    """
    series: dict[str, list[Path]] = {}

    for entry in sorted(upload_dir.iterdir()):
        if entry.is_dir():
            files = sorted(
                f for f in entry.iterdir()
                if f.is_file() and f.suffix.lower() in COMIC_EXTENSIONS
            )
            if files:
                series[entry.name] = files
        elif entry.is_file() and entry.suffix.lower() in COMIC_EXTENSIONS:
            name = series_name_from_file(entry.stem)
            series.setdefault(name, []).append(entry)

    # Sort file-based series files
    for name in series:
        series[name] = sorted(series[name])

    return series


def load_state() -> dict:
    if STATE_FILE.exists():
        with STATE_FILE.open() as f:
            return json.load(f)
    return {"series_order": [], "current_index": 0}


def save_state(state: dict, dry_run: bool) -> None:
    if dry_run:
        print(f"[dry-run] Would save state: {json.dumps(state)}")
        return
    with STATE_FILE.open("w") as f:
        json.dump(state, f, indent=2)


def update_series_order(state: dict, discovered: dict) -> list[str]:
    """Keep known series still present, append newly discovered ones."""
    known = [s for s in state["series_order"] if s in discovered]
    new = [s for s in discovered if s not in set(known)]
    return known + new


def pick_series(series_order: list[str], current_index: int, discovered: dict) -> tuple[int, str | None]:
    """Advance index (mod len), skipping series with no files. Returns (new_index, name)."""
    if not series_order:
        return current_index, None

    n = len(series_order)
    for offset in range(n):
        idx = (current_index + offset) % n
        name = series_order[idx]
        if name in discovered and discovered[name]:
            return idx, name

    return current_index, None


def files_to_move(files: list[Path], target_bytes: int) -> list[Path]:
    """Select files to move: all if total <= target, else accumulate until >= target."""
    total = sum(f.stat().st_size for f in files)
    if total <= target_bytes:
        return list(files)

    selected = []
    accumulated = 0
    for f in files:
        selected.append(f)
        accumulated += f.stat().st_size
        if accumulated >= target_bytes:
            break
    return selected


def move_files(
    files: list[Path],
    series_name: str,
    comics_dir: Path,
    upload_dir: Path,
    dry_run: bool,
) -> None:
    dest_dir = comics_dir / series_name
    if dry_run:
        print(f"[dry-run] Would create directory: {dest_dir}")
    else:
        dest_dir.mkdir(parents=True, exist_ok=True)

    for f in files:
        dest = dest_dir / f.name
        if dry_run:
            print(f"[dry-run] Would move: {f} -> {dest}")
        else:
            print(f"Moving: {f} -> {dest}")
            shutil.move(str(f), str(dest))

    # Clean up empty source directory
    if files:
        source_dir = files[0].parent
        if source_dir != upload_dir and source_dir.is_dir():
            remaining = list(source_dir.iterdir())
            if not remaining:
                if dry_run:
                    print(f"[dry-run] Would remove empty directory: {source_dir}")
                else:
                    print(f"Removing empty directory: {source_dir}")
                    source_dir.rmdir()


def notify(title: str, message: str, tags: str = "", priority: str = "default") -> None:
    """Send a notification via ntfy."""
    if not NTFY_TOKEN:
        return
    url = f"{NTFY_URL}/{NTFY_TOPIC}"
    headers = {
        "Authorization": f"Bearer {NTFY_TOKEN}",
        "Title": title,
        "Priority": priority,
    }
    if tags:
        headers["Tags"] = tags
    req = urllib.request.Request(url, data=message.encode(), headers=headers)
    try:
        urllib.request.urlopen(req, timeout=10).close()
    except Exception as exc:
        print(f"Warning: ntfy notification failed: {exc}", file=sys.stderr)


def scan_komga(dry_run: bool) -> None:
    """Trigger a library scan on all Komga libraries."""
    if dry_run:
        print("[dry-run] Would trigger Komga library scan")
        return
    token = b64encode(f"{KOMGA_USER}:{KOMGA_PASSWORD}".encode()).decode()
    headers = {"Authorization": f"Basic {token}"}
    try:
        req = urllib.request.Request(f"{KOMGA_URL}/api/v1/libraries", headers=headers)
        with urllib.request.urlopen(req, timeout=10) as resp:
            libraries = json.load(resp)
        for lib in libraries:
            lib_id = lib["id"]
            scan_req = urllib.request.Request(
                f"{KOMGA_URL}/api/v1/libraries/{lib_id}/scan",
                data=b"",
                headers=headers,
                method="POST",
            )
            urllib.request.urlopen(scan_req, timeout=10).close()
            print(f"Triggered Komga scan for library: {lib['name']!r}")
    except Exception as exc:
        print(f"Warning: Komga scan failed: {exc}", file=sys.stderr)


def load_schedule() -> list[str]:
    """Load the active series list. Empty list means all series are active."""
    if SCHEDULE_FILE.exists():
        try:
            data = json.loads(SCHEDULE_FILE.read_text())
            return data.get("active_series", [])
        except (json.JSONDecodeError, OSError):
            pass
    return []


def consume_pending() -> str | None:
    """Read and delete the pending series file set by the UI. Returns series name or None."""
    if PENDING_FILE.exists():
        name = PENDING_FILE.read_text().strip()
        PENDING_FILE.unlink()
        return name or None
    return None


def consume_trigger_user() -> str:
    """Read and delete the trigger user file. Returns user name or 'Scheduled'."""
    if TRIGGER_USER_FILE.exists():
        user = TRIGGER_USER_FILE.read_text().strip()
        TRIGGER_USER_FILE.unlink()
        return user or "Scheduled"
    return "Scheduled"


def main() -> None:
    parser = argparse.ArgumentParser(description="Manga Scheduler")
    parser.add_argument("--dry-run", action="store_true", help="Print actions without executing")
    parser.add_argument("--upload-dir", type=Path, default=UPLOAD_DIR, help="Override upload directory")
    parser.add_argument("--comics-dir", type=Path, default=COMICS_DIR, help="Override comics destination directory")
    parser.add_argument("--series", metavar="NAME", help="Deliver this series now instead of the next round-robin pick")
    args = parser.parse_args()

    upload_dir: Path = args.upload_dir
    comics_dir: Path = args.comics_dir

    if not upload_dir.is_dir():
        print(f"Upload directory does not exist: {upload_dir}", file=sys.stderr)
        sys.exit(1)

    discovered = discover_series(upload_dir)
    if not discovered:
        print("No series found in upload directory. Nothing to do.")
        sys.exit(0)

    state = load_state()
    series_order = update_series_order(state, discovered)

    if not series_order:
        print("No series to schedule. Nothing to do.")
        sys.exit(0)

    current_index = state.get("current_index", 0) % max(len(series_order), 1)

    # Determine which series to deliver: CLI flag > pending file > round-robin
    trigger_user = consume_trigger_user()
    forced_series = args.series or consume_pending()
    if forced_series:
        if forced_series not in discovered:
            print(f"Series {forced_series!r} not found in upload directory.", file=sys.stderr)
            sys.exit(1)
        chosen_series = forced_series
        # Find its index so we can advance past it for the next auto-run
        chosen_index = series_order.index(forced_series) if forced_series in series_order else current_index
    else:
        # Apply schedule filter: active series first, fallback to all
        active_series = load_schedule()
        if active_series:
            filtered = {s: files for s, files in discovered.items() if s in active_series}
            if filtered:
                chosen_index, chosen_series = pick_series(series_order, current_index, filtered)
            else:
                # All active series exhausted — fall back to full list
                chosen_index, chosen_series = pick_series(series_order, current_index, discovered)
        else:
            chosen_index, chosen_series = pick_series(series_order, current_index, discovered)

    if chosen_series is None:
        print("All series are empty. Nothing to do.")
        sys.exit(0)

    files = discovered[chosen_series]
    batch = files_to_move(files, TARGET_BYTES)

    total_mb = sum(f.stat().st_size for f in batch) / (1024 * 1024)
    print(f"Series: {chosen_series!r} ({len(files)} files remaining)")
    print(f"Moving {len(batch)} file(s) (~{total_mb:.1f} MB)")

    move_files(batch, chosen_series, comics_dir, upload_dir, args.dry_run)
    scan_komga(args.dry_run)

    if not args.dry_run:
        notify(
            f"📚 {chosen_series}",
            f"{len(batch)} file(s) delivered (~{total_mb:.1f} MB)\n"
            f"{len(files) - len(batch)} file(s) remaining\n"
            f"Triggered by: {trigger_user}",
            tags="books",
        )

    # Advance index for next run
    next_index = (chosen_index + 1) % len(series_order)
    new_state = {"series_order": series_order, "current_index": next_index}
    save_state(new_state, args.dry_run)

    print("Done.")


if __name__ == "__main__":
    main()
