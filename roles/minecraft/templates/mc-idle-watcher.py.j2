#!/usr/bin/env python3
"""Minecraft idle watcher — runs every 5 minutes via systemd timer.

Shuts down MC after idle_timeout seconds with no players.
The proxy and fake server stay up continuously — no management needed here.
"""

import json
import logging
import os
import re
import subprocess
import sys
import time

DATA_DIR = '{{ minecraft_data_dir }}'
LOCK_FILE = os.path.join(DATA_DIR, 'mc-starting.lock')
READY_FLAG = os.path.join(DATA_DIR, 'mc-ready.flag')
STATE_FILE = os.path.join(DATA_DIR, 'idle-state.json')
COMPOSE_FILE = os.path.join(DATA_DIR, 'docker-compose.yml')
IDLE_TIMEOUT = {{ minecraft_idle_timeout }}

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s %(levelname)s %(message)s',
)
log = logging.getLogger(__name__)


def run(cmd):
    return subprocess.run(cmd, capture_output=True, text=True)


def is_mc_running():
    result = run(['docker', 'ps', '--filter', 'name=^minecraft$', '--format', '{{ '{{' }}.Names{{ '}}' }}'])
    return 'minecraft' in result.stdout


def get_player_count():
    result = run(['docker', 'exec', 'minecraft', 'rcon-cli', 'list'])
    if result.returncode != 0:
        return 0
    m = re.search(r'There are (\d+)', result.stdout)
    return int(m.group(1)) if m else 0


def load_state():
    try:
        with open(STATE_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        # First run: initialise last_player to now to avoid immediate shutdown after reboot
        return {'last_player': time.time()}


def save_state(state):
    with open(STATE_FILE, 'w') as f:
        json.dump(state, f)


def main():
    now = time.time()

    if os.path.exists(LOCK_FILE):
        log.info("Startup in progress (lock exists), skipping.")
        sys.exit(0)

    if not is_mc_running():
        log.info("MC not running — nothing to do.")
        sys.exit(0)

    state = load_state()
    count = get_player_count()
    log.info("MC running, player count: %d", count)

    if count > 0:
        state['last_player'] = now
    else:
        idle_seconds = now - state.get('last_player', now)
        log.info("Idle for %.0fs / %ds timeout", idle_seconds, IDLE_TIMEOUT)
        if idle_seconds > IDLE_TIMEOUT:
            log.info("Idle timeout reached — shutting down MC")
            try:
                os.remove(READY_FLAG)
            except FileNotFoundError:
                pass
            subprocess.run(['docker', 'compose', '-f', COMPOSE_FILE, 'down'])

    save_state(state)


if __name__ == '__main__':
    main()
