#!/bin/bash
# Start the real Minecraft server.
# Called by mc-fake-server.py when a player attempts to connect.
set -euo pipefail

LOCK="{{ minecraft_data_dir }}/mc-starting.lock"
READY_FLAG="{{ minecraft_data_dir }}/mc-ready.flag"
COMPOSE_DIR="{{ minecraft_data_dir }}"

exec >> {{ minecraft_data_dir }}/mc-start.log 2>&1
echo "$(date -Iseconds) mc-start.sh: triggered"

touch "$LOCK"
trap 'rm -f "$LOCK"' EXIT

echo "$(date -Iseconds) Starting Minecraft..."
cd "$COMPOSE_DIR"
docker compose up -d

echo "$(date -Iseconds) Waiting for RCON (up to 5 min)..."
for i in $(seq 60); do
    sleep 5
    if docker exec minecraft rcon-cli list &>/dev/null; then
        echo "$(date -Iseconds) RCON ready after $((i * 5))s"
        break
    fi
done

echo "$(date -Iseconds) Waiting for game port :{{ minecraft_internal_port }} (up to 2 min)..."
for i in $(seq 24); do
    if (echo > /dev/tcp/127.0.0.1/{{ minecraft_internal_port }}) >/dev/null 2>&1; then
        echo "$(date -Iseconds) Game port ready after $((i * 5))s"
        break
    fi
    sleep 5
done

touch "$READY_FLAG"
echo "$(date -Iseconds) mc-start.sh: done"
