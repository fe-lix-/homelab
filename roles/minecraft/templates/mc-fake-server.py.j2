#!/usr/bin/env python3
"""Minimal Minecraft protocol fake server.

Listens on the internal fake port (not the public port — mc-proxy sits in front).
Shows a disconnect/MOTD message and triggers mc-start.sh on login attempt.
"""

import json
import logging
import os
import socket
import subprocess
import threading

HOST = '127.0.0.1'
PORT = {{ minecraft_fake_port }}
START_SCRIPT = '{{ minecraft_data_dir }}/mc-start.sh'
LOCK_FILE = '{{ minecraft_data_dir }}/mc-starting.lock'

MOTD_TEXT = "Server offline \u2014 connect to wake it up!"
DISCONNECT_TEXT = "\u00a7aServer is starting up!\n\u00a77Come back in \u00a7e5 minutes\u00a77."

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s %(levelname)s %(message)s',
)
log = logging.getLogger(__name__)

_trigger_lock = threading.Lock()


def read_varint(sock):
    result = 0
    shift = 0
    while True:
        b = sock.recv(1)
        if not b:
            raise ConnectionError("Connection closed")
        val = b[0]
        result |= (val & 0x7F) << shift
        if not (val & 0x80):
            break
        shift += 7
    return result


def write_varint(value):
    out = b''
    while True:
        part = value & 0x7F
        value >>= 7
        if value:
            part |= 0x80
        out += bytes([part])
        if not value:
            break
    return out


def write_string(s):
    encoded = s.encode('utf-8')
    return write_varint(len(encoded)) + encoded


def send_packet(sock, packet_id, data=b''):
    payload = write_varint(packet_id) + data
    packet = write_varint(len(payload)) + payload
    sock.sendall(packet)


def read_packet(sock):
    length = read_varint(sock)
    data = b''
    while len(data) < length:
        chunk = sock.recv(length - len(data))
        if not chunk:
            raise ConnectionError("Connection closed")
        data += chunk
    packet_id = 0
    shift = 0
    i = 0
    while True:
        val = data[i]
        i += 1
        packet_id |= (val & 0x7F) << shift
        if not (val & 0x80):
            break
        shift += 7
    return packet_id, data[i:]


def parse_varint_from(data, i):
    result = 0
    shift = 0
    while True:
        val = data[i]
        i += 1
        result |= (val & 0x7F) << shift
        if not (val & 0x80):
            break
        shift += 7
    return result, i


def trigger_startup():
    # Use a lock to avoid concurrent triggers from multiple simultaneous connections
    with _trigger_lock:
        if os.path.exists(LOCK_FILE):
            log.info("Startup already in progress (lock exists), skipping.")
            return
        # Check if MC container is already running
        result = subprocess.run(
            ['docker', 'ps', '--filter', 'name=^minecraft$', '--format', '{{ '{{' }}.Names{{ '}}' }}'],
            capture_output=True, text=True,
        )
        if 'minecraft' in result.stdout:
            log.info("MC is already running, skipping startup trigger.")
            return
        log.info("Login attempt detected — triggering MC startup")
        subprocess.Popen([START_SCRIPT], start_new_session=True)


def handle_client(conn, addr):
    log.info("Connection from %s", addr)
    try:
        packet_id, data = read_packet(conn)
        if packet_id != 0x00:
            return

        i = 0
        proto_version, i = parse_varint_from(data, i)
        str_len, i = parse_varint_from(data, i)
        i += str_len  # skip server_address
        i += 2        # skip server_port
        next_state, i = parse_varint_from(data, i)

        if next_state == 1:
            read_packet(conn)  # consume Status Request
            status = {
                "version": {"name": "Offline", "protocol": proto_version},
                "players": {"max": 0, "online": 0, "sample": []},
                "description": {"text": MOTD_TEXT},
            }
            send_packet(conn, 0x00, write_string(json.dumps(status)))
            try:
                pid, pdata = read_packet(conn)
                if pid == 0x01:
                    send_packet(conn, 0x01, pdata)
            except Exception:
                pass

        elif next_state == 2:
            read_packet(conn)  # consume Login Start
            reason = json.dumps({"text": DISCONNECT_TEXT})
            send_packet(conn, 0x00, write_string(reason))
            trigger_startup()

    except Exception as e:
        log.debug("Client %s: %s", addr, e)
    finally:
        conn.close()


def main():
    log.info("mc-fake-server starting on 127.0.0.1:%d", PORT)
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as srv:
        srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        srv.bind((HOST, PORT))
        srv.listen(8)
        while True:
            try:
                conn, addr = srv.accept()
                threading.Thread(target=handle_client, args=(conn, addr), daemon=True).start()
            except Exception as e:
                log.error("Accept error: %s", e)


if __name__ == '__main__':
    main()
