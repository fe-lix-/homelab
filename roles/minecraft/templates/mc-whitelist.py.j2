#!/usr/bin/env python3
"""Minecraft IP whitelist HTTP service.

On GET /, reads the caller's IP from X-Real-IP (set by nginx),
adds it to the whitelist JSON with a 48-hour TTL, and returns
a success page.
"""

import json
import os
import time
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, HTTPServer

WHITELIST_FILE = '{{ minecraft_data_dir }}/ip-whitelist.json'
LISTEN_HOST = '127.0.0.1'
LISTEN_PORT = {{ minecraft_whitelist_port }}
TTL = 48 * 3600


def load_whitelist():
    try:
        with open(WHITELIST_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def save_whitelist(whitelist):
    tmp = WHITELIST_FILE + '.tmp'
    with open(tmp, 'w') as f:
        json.dump(whitelist, f)
    os.replace(tmp, WHITELIST_FILE)


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        # Use stdout so systemd captures it
        print(fmt % args)

    def do_GET(self):
        if self.path != '/':
            self.send_response(404)
            self.end_headers()
            return

        client_ip = self.headers.get('X-Real-IP', self.client_address[0])
        now = time.time()
        expiry = now + TTL

        whitelist = load_whitelist()
        # Prune expired entries
        whitelist = dict((ip, exp) for ip, exp in whitelist.items() if exp > now)
        whitelist[client_ip] = expiry
        save_whitelist(whitelist)

        expiry_dt = datetime.fromtimestamp(expiry, tz=timezone.utc)
        expiry_str = expiry_dt.strftime('%Y-%m-%d %H:%M UTC')

        body = (
{% raw %}            f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Minecraft Whitelist</title>
  <style>
    body {{ font-family: sans-serif; max-width: 600px; margin: 4rem auto; padding: 1rem; }}
    .box {{ background: #e8f5e9; border: 1px solid #a5d6a7; border-radius: 8px; padding: 1.5rem; }}
    code {{ background: #f5f5f5; padding: 0.2em 0.4em; border-radius: 4px; }}
  </style>
</head>
<body>
  <div class="box">
    <h2>You're whitelisted!</h2>
    <p>Your IP <code>{client_ip}</code> has been added to the Minecraft whitelist.</p>
    <p>Access expires: <strong>{expiry_str}</strong></p>
    <p>Connect to: <code>minecraft.{{ base_domain }}</code></p>
    <p>After expiry, visit this page again to re-whitelist your IP.</p>
  </div>
</body>
</html>
"""{% endraw %}
        ).encode()

        self.send_response(200)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.send_header('Content-Length', str(len(body)))
        self.end_headers()
        self.wfile.write(body)


if __name__ == '__main__':
    server = HTTPServer((LISTEN_HOST, LISTEN_PORT), Handler)
    print(f'mc-whitelist listening on {LISTEN_HOST}:{LISTEN_PORT}')
    server.serve_forever()
