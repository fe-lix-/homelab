/* Khazad-dûm theme — stone & amber */

/* Amber accent on service card hover */
.service-card:hover {
  border-color: rgb(245 158 11) !important; /* amber-500 */
  box-shadow: 0 0 12px rgba(245, 158, 11, 0.3);
}

/* Amber highlight on widget values */
#information-widgets span.text-theme-800,
#information-widgets span.text-theme-700 {
  color: rgb(251 191 36) !important; /* amber-400 */
}

/* Page title */
#site-title {
  color: rgb(251 191 36) !important;
  letter-spacing: 0.05em;
  text-shadow: 0 0 20px rgba(245, 158, 11, 0.5);
}

/* Section headers */
.service-group h2 {
  color: rgb(214 163 73) !important;
  border-bottom: 1px solid rgba(214, 163, 73, 0.3);
  padding-bottom: 0.25rem;
}

/* Subtle stone texture on cards */
.service-card {
  background: rgba(28, 25, 23, 0.85) !important; /* stone-900 tinted */
  border-color: rgba(120, 113, 108, 0.3) !important; /* stone-500 */
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

/* Background overlay for depth */
body {
  background-color: rgb(12, 10, 9) !important; /* near-black stone */
}
