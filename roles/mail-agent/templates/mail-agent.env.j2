# Managed by Ansible — do not edit by hand. Loaded by mail-agent.service via
# EnvironmentFile=. Mode 0640 root:mailagent so the secrets stay readable only
# to the service user.
MAIL_AGENT_IMAP_HOST={{ mail_agent_imap_host }}
MAIL_AGENT_IMAP_PORT={{ mail_agent_imap_port }}
MAIL_AGENT_IMAP_USER={{ mail_agent_imap_user }}
MAIL_AGENT_IMAP_PASSWORD={{ mail_agent_imap_password }}
MAIL_AGENT_IMAP_FOLDER={{ mail_agent_imap_folder }}
MAIL_AGENT_SMTP_HOST={{ mail_agent_smtp_host }}
MAIL_AGENT_SMTP_PORT={{ mail_agent_smtp_port }}
MAIL_AGENT_REPLY_FROM={{ mail_agent_reply_from }}
MAIL_AGENT_ALLOWED_SENDERS={{ mail_agent_allowed_senders | join(',') }}
MAIL_AGENT_MIN_DELAY_SECONDS={{ mail_agent_min_delay_seconds }}
MAIL_AGENT_MAX_DELAY_SECONDS={{ mail_agent_max_delay_seconds }}
MAIL_AGENT_MODEL={{ mail_agent_model }}
MAIL_AGENT_DATA_DIR={{ mail_agent_data_dir }}
MAIL_AGENT_ANTHROPIC_API_KEY={{ mail_agent_anthropic_api_key }}
# The bundled Claude Code CLI inside claude-agent-sdk reads ANTHROPIC_API_KEY
# directly from its environment — without it, it falls back to OAuth login
# and times out during the SDK's `initialize` handshake.
ANTHROPIC_API_KEY={{ mail_agent_anthropic_api_key }}
MAIL_AGENT_PERSONA={{ mail_agent_persona | replace('\n', '\\n') }}
